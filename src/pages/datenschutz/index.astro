---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Privacy Policy — MasalNova"
  description="Privacy Policy of MasalNova Çocuk."
  path="/datenschutz/"
  noindex={true}
>
  <section class="section">
    <div class="container">
      <article class="legal" lang="en">
        <h1>Privacy Policy</h1>
        <img class="legal-img" src="/privacy.png" alt="MasalNova Privacy Policy" />

        <a class="btn btn-ghost" href="/">← Home</a>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .legal { background: #fff; color: var(--ink); border-radius: var(--radius-lg); padding: 32px clamp(20px, 5vw, 46px); box-shadow: var(--shadow-lg); border: 1px solid var(--line); max-width: 900px; margin: 0 auto; }
  .legal h1 { font-size: clamp(1.6rem, 4vw, 2.3rem); margin-bottom: 18px; }
  .legal-img { width: 100%; border-radius: var(--radius); border: 1px solid var(--line); }
  .legal .btn { margin-top: 24px; border-color: var(--blue); color: var(--blue-d); }
</style>
