---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getStories } from '../../data/stories';
import { ageLabel, storyCategoryLabel } from '../../data/taxonomy';

const stories = await getStories();
const catalog = stories.map((story) => ({
  id: story.id,
  title: story.data.title,
  description: story.data.shortDescription,
  href: `/masallar/${story.id}/`,
  coverImage: story.data.coverImage ?? '',
  coverEmoji: story.data.coverEmoji,
  coverColor: story.data.coverColor,
  coverAlt: story.data.altText ?? `${story.data.title} resimli masal kapağı`,
  age: story.data.ageGroups.map(ageLabel).join(' · ') || 'Her yaş',
  minutes: story.data.readingTime,
  category: story.data.categories[0]
    ? storyCategoryLabel(story.data.categories[0])
    : 'Çocuk Masalı',
}));
const catalogJson = JSON.stringify(catalog).replace(/</g, '\\u003c');
---

<BaseLayout
  title="Kitaplığım – Favoriler ve Okumaya Devam Et | MasalNova"
  description="Bu cihazda kaydettiğiniz ve okumaya başladığınız MasalNova masallarını tek yerde görün."
  path="/kitapligim/"
  noindex
  activeNav="library"
>
  <section class="library-page" data-library-root data-library-state="loading">
    <div class="container">
      <header class="library-hero">
        <p class="library-kicker">Senin küçük masal rafın</p>
        <h1>Kitaplığım</h1>
        <p>Favorilerin, son okudukların ve kaldığın yer yalnızca bu cihazda saklanır.</p>
      </header>

      <div class="library-loading" data-library-loading role="status" aria-live="polite">
        <span aria-hidden="true"></span>
        Kitaplığın hazırlanıyor…
      </div>

      <section class="resume-section" data-library-resume hidden aria-labelledby="resume-title">
        <div class="section-heading">
          <div>
            <p>Okumaya devam et</p>
            <h2 id="resume-title">Kaldığın yer seni bekliyor</h2>
          </div>
        </div>

        <a class="resume-card" data-resume-link>
          <div class="resume-card__visual" data-resume-visual>
            <img data-resume-image alt="" width="960" height="640" hidden />
            <span data-resume-fallback aria-hidden="true">📖</span>
          </div>
          <div class="resume-card__body">
            <p data-resume-meta></p>
            <h3 data-resume-title></h3>
            <p data-resume-description></p>
            <div class="resume-card__progress" aria-hidden="true"><span data-resume-progress></span></div>
            <small data-resume-progress-label></small>
            <strong>Devam et <i class="ph ph-arrow-right" aria-hidden="true"></i></strong>
          </div>
        </a>
      </section>

      <section class="shelf-section" data-library-favorites hidden aria-labelledby="favorites-title">
        <div class="section-heading">
          <div>
            <p>Kaydettiğin masallar</p>
            <h2 id="favorites-title">Favorilerin</h2>
          </div>
          <span data-favorite-count></span>
        </div>
        <div class="library-grid" data-favorites-list></div>
      </section>

      <section class="shelf-section" data-library-recent hidden aria-labelledby="recent-title">
        <div class="section-heading">
          <div>
            <p>Son okunanlar</p>
            <h2 id="recent-title">Yakın zamandaki maceraların</h2>
          </div>
          <span data-recent-count></span>
        </div>
        <div class="library-grid" data-recent-list></div>
      </section>

      <section class="library-empty" data-library-empty hidden aria-labelledby="empty-title">
        <div class="library-empty__icon" aria-hidden="true"><i class="ph ph-book-bookmark"></i></div>
        <p class="library-kicker">Burada yeni masallar için yer var</p>
        <h2 id="empty-title">Kendi masal rafını oluşturmaya başla.</h2>
        <p>Bir masalı favorilere ekle veya okumaya başla; sonra burada kolayca bulabilirsin.</p>
        <a href="/masallar/">Masalları keşfet <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
      </section>

      <noscript>
        <p class="library-noscript">Favorilerini ve okuma ilerlemeni gösterebilmek için JavaScript'i etkinleştir.</p>
      </noscript>

      <template data-library-card-template>
        <article class="library-card">
          <a class="library-card__link" data-card-link>
            <div class="library-card__visual" data-card-visual>
              <img data-card-image alt="" width="560" height="420" loading="lazy" hidden />
              <span data-card-fallback aria-hidden="true">📖</span>
              <small data-card-category></small>
            </div>
            <div class="library-card__body">
              <p data-card-meta></p>
              <h3 data-card-title></h3>
              <p data-card-description></p>
              <div class="library-card__progress" aria-hidden="true"><span data-card-progress></span></div>
              <strong data-card-cta>Masalı aç <i class="ph ph-arrow-right" aria-hidden="true"></i></strong>
            </div>
          </a>
          <button
            class="library-card__favorite"
            type="button"
            data-library-favorite
            aria-pressed="false"
          >
            <i class="ph ph-heart" aria-hidden="true"></i>
            <span class="sr-only">Favorilere ekle</span>
          </button>
        </article>
      </template>

      <script type="application/json" id="library-catalog" set:html={catalogJson}></script>
    </div>
  </section>
</BaseLayout>

<script>
  import {
    APP_STATE_CHANGE_EVENT,
    APP_STATE_STORAGE_KEY,
    getState,
    toggleFavorite,
    type AppState,
  } from '../../lib/app-state';

  type CatalogStory = {
    id: string;
    title: string;
    description: string;
    href: string;
    coverImage: string;
    coverEmoji: string;
    coverColor: string;
    coverAlt: string;
    age: string;
    minutes: number;
    category: string;
  };

  const root = document.querySelector<HTMLElement>('[data-library-root]');
  const loading = document.querySelector<HTMLElement>('[data-library-loading]');
  const resumeSection = document.querySelector<HTMLElement>('[data-library-resume]');
  const favoritesSection = document.querySelector<HTMLElement>('[data-library-favorites]');
  const recentSection = document.querySelector<HTMLElement>('[data-library-recent]');
  const emptySection = document.querySelector<HTMLElement>('[data-library-empty]');
  const favoritesList = document.querySelector<HTMLElement>('[data-favorites-list]');
  const recentList = document.querySelector<HTMLElement>('[data-recent-list]');
  const favoriteCount = document.querySelector<HTMLElement>('[data-favorite-count]');
  const recentCount = document.querySelector<HTMLElement>('[data-recent-count]');
  const cardTemplate = document.querySelector<HTMLTemplateElement>('[data-library-card-template]');
  const catalogNode = document.querySelector<HTMLScriptElement>('#library-catalog');

  let catalog: CatalogStory[] = [];
  try {
    const parsed = JSON.parse(catalogNode?.textContent || '[]');
    if (Array.isArray(parsed)) catalog = parsed as CatalogStory[];
  } catch {
    catalog = [];
  }

  const storyById = new Map(catalog.map((story) => [story.id, story]));

  const setVisual = (
    visual: HTMLElement | null,
    image: HTMLImageElement | null,
    fallback: HTMLElement | null,
    story: CatalogStory,
  ) => {
    if (visual) visual.style.setProperty('--cover-color', story.coverColor);
    if (story.coverImage && image) {
      image.src = story.coverImage;
      image.alt = story.coverAlt;
      image.hidden = false;
      if (fallback) fallback.hidden = true;
    } else {
      if (image) image.hidden = true;
      if (fallback) {
        fallback.textContent = story.coverEmoji;
        fallback.hidden = false;
      }
    }
  };

  const createCard = (story: CatalogStory, state: AppState, recent = false): HTMLElement | null => {
    const card = cardTemplate?.content.firstElementChild?.cloneNode(true) as HTMLElement | null;
    if (!card) return null;

    const progress = state.progress[story.id] ?? 0;
    const favorite = state.favorites.includes(story.id);
    const link = card.querySelector<HTMLAnchorElement>('[data-card-link]');
    if (link) link.href = story.href;

    setVisual(
      card.querySelector<HTMLElement>('[data-card-visual]'),
      card.querySelector<HTMLImageElement>('[data-card-image]'),
      card.querySelector<HTMLElement>('[data-card-fallback]'),
      story,
    );

    const category = card.querySelector<HTMLElement>('[data-card-category]');
    const meta = card.querySelector<HTMLElement>('[data-card-meta]');
    const title = card.querySelector<HTMLElement>('[data-card-title]');
    const description = card.querySelector<HTMLElement>('[data-card-description]');
    const progressBar = card.querySelector<HTMLElement>('[data-card-progress]');
    const cta = card.querySelector<HTMLElement>('[data-card-cta]');
    if (category) category.textContent = story.category;
    if (meta) meta.textContent = `${story.age} · ${story.minutes} dk`;
    if (title) title.textContent = story.title;
    if (description) description.textContent = story.description;
    if (progressBar) progressBar.style.width = `${progress}%`;
    if (cta?.firstChild) cta.firstChild.textContent = recent && progress > 0 ? 'Devam et ' : 'Masalı aç ';

    const favoriteButton = card.querySelector<HTMLButtonElement>('[data-library-favorite]');
    if (favoriteButton) {
      favoriteButton.dataset.libraryFavorite = story.id;
      favoriteButton.setAttribute('aria-pressed', String(favorite));
      favoriteButton.setAttribute('aria-label', favorite
        ? `${story.title} masalını favorilerden çıkar`
        : `${story.title} masalını favorilere ekle`);
      const icon = favoriteButton.querySelector<HTMLElement>('i');
      const hiddenLabel = favoriteButton.querySelector<HTMLElement>('.sr-only');
      if (icon) icon.className = favorite ? 'ph-fill ph-heart' : 'ph ph-heart';
      if (hiddenLabel) hiddenLabel.textContent = favorite ? 'Favorilerden çıkar' : 'Favorilere ekle';
    }

    return card;
  };

  const renderList = (
    target: HTMLElement | null,
    storiesToRender: CatalogStory[],
    state: AppState,
    recent = false,
  ) => {
    if (!target) return;
    const fragment = document.createDocumentFragment();
    for (const story of storiesToRender) {
      const card = createCard(story, state, recent);
      if (card) fragment.append(card);
    }
    target.replaceChildren(fragment);
  };

  const renderResume = (story: CatalogStory | undefined, state: AppState) => {
    if (!resumeSection) return;
    resumeSection.hidden = !story;
    if (!story) return;

    const link = resumeSection.querySelector<HTMLAnchorElement>('[data-resume-link]');
    if (link) link.href = story.href;
    setVisual(
      resumeSection.querySelector<HTMLElement>('[data-resume-visual]'),
      resumeSection.querySelector<HTMLImageElement>('[data-resume-image]'),
      resumeSection.querySelector<HTMLElement>('[data-resume-fallback]'),
      story,
    );

    const progress = state.progress[story.id] ?? 0;
    const meta = resumeSection.querySelector<HTMLElement>('[data-resume-meta]');
    const title = resumeSection.querySelector<HTMLElement>('[data-resume-title]');
    const description = resumeSection.querySelector<HTMLElement>('[data-resume-description]');
    const progressBar = resumeSection.querySelector<HTMLElement>('[data-resume-progress]');
    const progressLabel = resumeSection.querySelector<HTMLElement>('[data-resume-progress-label]');
    if (meta) meta.textContent = `${story.category} · ${story.minutes} dk`;
    if (title) title.textContent = story.title;
    if (description) description.textContent = story.description;
    if (progressBar) progressBar.style.width = `${progress}%`;
    if (progressLabel) progressLabel.textContent = progress > 0
      ? `%${progress} tamamlandı`
      : 'Okumaya başlamaya hazır';
  };

  const render = (state: AppState) => {
    const favorites = state.favorites
      .map((id) => storyById.get(id))
      .filter((story): story is CatalogStory => Boolean(story));
    const recent = state.recentStoryIds
      .map((id) => storyById.get(id))
      .filter((story): story is CatalogStory => Boolean(story));
    const resume = recent.find((story) => (state.progress[story.id] ?? 0) < 100) ?? recent[0];

    renderResume(resume, state);
    renderList(favoritesList, favorites, state);
    renderList(recentList, recent, state, true);

    if (favoritesSection) favoritesSection.hidden = favorites.length === 0;
    if (recentSection) recentSection.hidden = recent.length === 0;
    if (emptySection) emptySection.hidden = favorites.length > 0 || recent.length > 0;
    if (favoriteCount) favoriteCount.textContent = `${favorites.length} masal`;
    if (recentCount) recentCount.textContent = `${recent.length} masal`;
    if (loading) loading.hidden = true;
    if (root) root.dataset.libraryState = 'ready';
  };

  root?.addEventListener('click', (event) => {
    if (!(event.target instanceof Element)) return;
    const button = event.target.closest<HTMLButtonElement>('[data-library-favorite]');
    const storyId = button?.dataset.libraryFavorite;
    if (storyId) toggleFavorite(storyId);
  });

  window.addEventListener(APP_STATE_CHANGE_EVENT, () => render(getState()));
  window.addEventListener('storage', (event) => {
    if (event.key === APP_STATE_STORAGE_KEY) render(getState());
  });
  render(getState());
</script>

<style>
  .library-page {
    min-height: calc(100dvh - var(--app-nav-height));
    padding: clamp(34px, 5vw, 64px) 0 74px;
    color: #fff;
  }

  .library-hero { max-width: 760px; }
  .library-kicker,
  .section-heading p {
    color: #ffd66c;
    font-size: .76rem;
    font-weight: 900;
    letter-spacing: .11em;
    text-transform: uppercase;
  }
  .library-hero h1 { margin-top: 7px; font-size: clamp(2.7rem, 7vw, 5.2rem); letter-spacing: -.055em; }
  .library-hero > p:last-child { max-width: 62ch; margin-top: 12px; color: rgba(255,255,255,.78); font-size: 1.04rem; }

  .library-loading {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 34px;
    color: rgba(255,255,255,.78);
    font-weight: 800;
  }
  .library-loading[hidden] { display: none; }
  .library-loading span { width: 10px; height: 10px; border-radius: 50%; background: var(--app-yellow); animation: library-pulse 1s ease-in-out infinite alternate; }

  .resume-section,
  .shelf-section { margin-top: clamp(42px, 7vw, 72px); }
  .resume-section[hidden],
  .shelf-section[hidden],
  .library-empty[hidden] { display: none; }
  .section-heading { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 18px; }
  .section-heading h2 { margin-top: 5px; font-size: clamp(1.55rem, 3.5vw, 2.35rem); }
  .section-heading > span { color: rgba(255,255,255,.68); font-size: .82rem; font-weight: 850; }

  .resume-card {
    display: grid;
    grid-template-columns: minmax(280px, .9fr) minmax(0, 1.1fr);
    min-height: 330px;
    overflow: hidden;
    border: 1px solid rgba(255,219,118,.42);
    border-radius: 30px;
    background: linear-gradient(145deg, rgba(22,69,163,.96), rgba(8,32,94,.96));
    box-shadow: 0 28px 72px rgba(2,16,62,.3);
    transition: transform .22s ease, border-color .22s ease;
  }
  .resume-card:hover { transform: translateY(-4px); border-color: #ffdb76; }
  .resume-card__visual,
  .library-card__visual { position: relative; display: grid; place-items: center; overflow: hidden; background: var(--cover-color, #173b84); }
  .resume-card__visual img,
  .library-card__visual img { width: 100%; height: 100%; object-fit: cover; }
  .resume-card__visual > span,
  .library-card__visual > span { font-size: 4rem; filter: drop-shadow(0 10px 20px rgba(0,0,0,.24)); }
  .resume-card__body { display: flex; flex-direction: column; justify-content: center; align-items: flex-start; padding: clamp(25px, 5vw, 52px); }
  .resume-card__body > p:first-child,
  .library-card__body > p:first-child { color: #aecaFF; font-size: .73rem; font-weight: 900; letter-spacing: .04em; text-transform: uppercase; }
  .resume-card h3 { max-width: 18ch; margin-top: 8px; font-size: clamp(1.8rem, 4vw, 3rem); letter-spacing: -.035em; }
  .resume-card__body > p:nth-of-type(2) { display: -webkit-box; max-width: 58ch; margin-top: 12px; overflow: hidden; color: rgba(255,255,255,.82); -webkit-box-orient: vertical; -webkit-line-clamp: 3; }
  .resume-card__progress,
  .library-card__progress { width: 100%; height: 5px; overflow: hidden; margin-top: 22px; border-radius: 999px; background: rgba(255,255,255,.15); }
  .resume-card__progress span,
  .library-card__progress span { display: block; width: 0; height: 100%; border-radius: inherit; background: var(--app-yellow); transition: width .3s ease; }
  .resume-card small { margin-top: 7px; color: rgba(255,255,255,.66); font-weight: 800; }
  .resume-card strong,
  .library-card strong { display: inline-flex; align-items: center; gap: 8px; margin-top: 18px; color: #ffdc79; font-size: .86rem; font-weight: 900; }

  .library-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
  .library-card { position: relative; min-width: 0; overflow: hidden; border: 1px solid rgba(255,255,255,.16); border-radius: 23px; background: rgba(255,255,255,.1); box-shadow: 0 18px 46px rgba(2,18,70,.18); transition: transform .2s ease, background .2s ease; }
  .library-card:hover { transform: translateY(-3px); background: rgba(255,255,255,.14); }
  .library-card__link { display: grid; grid-template-columns: 148px minmax(0, 1fr); min-height: 190px; }
  .library-card__visual small { position: absolute; right: 9px; bottom: 9px; max-width: calc(100% - 18px); overflow: hidden; padding: 5px 8px; border-radius: 999px; background: rgba(4,22,69,.8); color: #fff; font-size: .62rem; font-weight: 850; text-overflow: ellipsis; white-space: nowrap; }
  .library-card__body { display: flex; flex-direction: column; align-items: flex-start; min-width: 0; padding: 18px 18px 16px; }
  .library-card h3 { display: -webkit-box; margin-top: 5px; overflow: hidden; font-size: 1.08rem; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
  .library-card__body > p:nth-of-type(2) { display: -webkit-box; margin-top: 7px; overflow: hidden; color: rgba(255,255,255,.72); font-size: .78rem; line-height: 1.42; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
  .library-card__progress { margin-top: auto; }
  .library-card strong { margin-top: 8px; font-size: .76rem; }
  .library-card__favorite { position: absolute; z-index: 2; top: 10px; left: 10px; display: grid; place-items: center; width: 40px; height: 40px; border: 1px solid rgba(255,255,255,.28); border-radius: 50%; background: rgba(4,22,69,.78); color: #fff; font-size: 1.08rem; backdrop-filter: blur(10px); }
  .library-card__favorite[aria-pressed='true'] { background: #fff; color: #e23b68; }

  .library-empty { max-width: 690px; margin: clamp(48px, 10vw, 100px) auto 0; padding: clamp(30px, 6vw, 58px); border: 1px solid rgba(255,255,255,.2); border-radius: 30px; background: rgba(255,255,255,.1); text-align: center; }
  .library-empty__icon { display: grid; place-items: center; width: 68px; height: 68px; margin: 0 auto 18px; border-radius: 22px; background: rgba(255,209,73,.17); color: #ffda70; font-size: 2rem; }
  .library-empty h2 { margin-top: 7px; font-size: clamp(1.8rem, 5vw, 3rem); }
  .library-empty > p:nth-of-type(2) { max-width: 52ch; margin: 14px auto 0; color: rgba(255,255,255,.76); }
  .library-empty > a { display: inline-flex; align-items: center; gap: 9px; margin-top: 24px; padding: 12px 18px; border-radius: 999px; background: var(--app-yellow); color: #17336f; font-weight: 900; }
  .library-noscript { margin-top: 28px; padding: 14px 16px; border-radius: 14px; background: rgba(255,255,255,.12); color: #fff; }

  @keyframes library-pulse { to { transform: scale(1.45); opacity: .45; } }

  @media (max-width: 840px) {
    .resume-card { grid-template-columns: 1fr; }
    .resume-card__visual { min-height: 280px; }
    .library-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 560px) {
    .library-page { padding-top: 30px; }
    .library-hero h1 { font-size: 2.75rem; }
    .section-heading { align-items: flex-start; flex-direction: column; gap: 7px; }
    .resume-card { border-radius: 23px; }
    .resume-card__visual { min-height: 220px; }
    .resume-card__body { padding: 22px; }
    .library-card { border-radius: 19px; }
    .library-card__link { grid-template-columns: 104px minmax(0, 1fr); min-height: 166px; }
    .library-card__body { padding: 14px 13px; }
    .library-card__body > p:nth-of-type(2) { -webkit-line-clamp: 1; }
    .library-card__favorite { top: 8px; left: 8px; width: 36px; height: 36px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .library-loading span { animation: none; }
    .resume-card,
    .library-card { transition: none; }
  }
</style>
