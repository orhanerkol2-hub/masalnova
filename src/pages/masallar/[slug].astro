---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CoverThumb from '../../components/CoverThumb.astro';
import VideoCard from '../../components/VideoCard.astro';
import StoryCard from '../../components/StoryCard.astro';
import ReadingToolbar from '../../components/ReadingToolbar.astro';
import { getStories } from '../../data/stories';
import { videoById } from '../../data/videos';
import { ageLabel, storyCategoryLabel } from '../../data/taxonomy';
import { compactDescription, formatTurkishDate, storySeoTitle } from '../../lib/seo';

export async function getStaticPaths() {
  const stories = await getStories();
  return stories.map((story) => ({ params: { slug: story.id }, props: { story } }));
}

const { story } = Astro.props;
const d = story.data;
const { Content } = await render(story);

const allStories = await getStories();
const related = d.relatedVideoIds.map((id) => videoById(id)).filter(Boolean);
const moreStories = allStories
  .filter((s) => s.id !== story.id && s.data.categories.some((c) => d.categories.includes(c)))
  .slice(0, 3);
const primaryCategory = d.categories[0];
const primaryCategoryLabel = primaryCategory ? storyCategoryLabel(primaryCategory) : 'Masallar';
const storyUrl = `https://masalnova.com/masallar/${story.id}/`;
const storyImage = d.coverImage ? `https://masalnova.com${d.coverImage}` : 'https://masalnova.com/logo.png';
const publishedIso = `${d.publishedAt}T00:00:00+03:00`;
const publishedLabel = formatTurkishDate(d.publishedAt);
const seoDescription = compactDescription(d.shortDescription);
const seoTitle = d.seoTitle ?? storySeoTitle(d.title);
const ageRange = d.ageGroups.map(ageLabel).join(' ve ');
const primaryTheme = d.themes[0] ?? 'hikâyenin ana fikri';
const ageBounds = d.ageGroups[0]?.split('-').map(Number) ?? [];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    '@id': `${storyUrl}#article`,
    url: storyUrl,
    headline: d.title,
    description: seoDescription,
    image: [storyImage],
    inLanguage: 'tr-TR',
    datePublished: publishedIso,
    isAccessibleForFree: true,
    articleSection: d.categories.map(storyCategoryLabel),
    genre: d.categories.map(storyCategoryLabel),
    keywords: (d.seoKeywords.length
      ? d.seoKeywords
      : [...d.themes, ...d.categories.map(storyCategoryLabel)]).join(', '),
    timeRequired: `PT${d.readingTime}M`,
    about: d.themes.map((theme) => ({ '@type': 'Thing', name: theme })),
    audience: ageBounds.length === 2 ? {
      '@type': 'PeopleAudience',
      suggestedMinAge: ageBounds[0],
      suggestedMaxAge: ageBounds[1],
    } : undefined,
    author: {
      '@type': 'Organization',
      name: 'MasalNova Çocuk Editör Ekibi',
      url: 'https://masalnova.com/hakkimizda/',
    },
    publisher: { '@id': 'https://masalnova.com/#organization' },
    mainEntityOfPage: { '@type': 'WebPage', '@id': storyUrl },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: 'https://masalnova.com/' },
      { '@type': 'ListItem', position: 2, name: 'Masallar', item: 'https://masalnova.com/masallar/' },
      ...(primaryCategory ? [{ '@type': 'ListItem', position: 3, name: primaryCategoryLabel, item: `https://masalnova.com/masallar/kategori/${primaryCategory}/` }] : []),
      { '@type': 'ListItem', position: primaryCategory ? 4 : 3, name: d.title, item: storyUrl },
    ],
  },
];
---
<BaseLayout
  title={seoTitle}
  description={seoDescription}
  path={`/masallar/${story.id}/`}
  image={d.coverImage}
  imageAlt={d.altText ?? `${d.title} resimli masal kapağı`}
  ogType="article"
  publishedTime={publishedIso}
  preloadImage={d.coverImage}
  jsonLd={jsonLd}
  activeNav="masallar"
  readerPage
>
  <ReadingToolbar backHref="/masallar/" audioSrc={d.audioUrl} storyId={story.id} />

  <section class="story-page">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Ana Sayfa</a> <span>›</span> <a href="/masallar/">Masallar</a>
        {primaryCategory && <><span>›</span><a href={`/masallar/kategori/${primaryCategory}/`}>{primaryCategoryLabel}</a></>}
        <span>›</span> <span>{d.title}</span>
      </nav>

      <div class="reader-shell">
        <article class="reader" data-reader-article>
          <header class="reader__header">
            <span class="reader__eyebrow">MasalNova Reader</span>
            <h1 class="reader__title">{d.title}</h1>
            <p class="reader__description">{d.shortDescription}</p>
            <div class="reader__meta">
              {d.ageGroups.map((a) => <span>{ageLabel(a)}</span>)}
              <span aria-hidden="true">·</span>
              <span>{d.readingTime} dk okuma</span>
              {d.categories.map((c) => (
                <>
                  <span aria-hidden="true">·</span>
                  <a href={`/masallar/kategori/${c}/`}>{storyCategoryLabel(c)}</a>
                </>
              ))}
            </div>
            <p class="reader__byline">
              <span>MasalNova Çocuk Editör Ekibi</span>
              <span aria-hidden="true">·</span>
              <time datetime={publishedIso}>{publishedLabel} tarihinde yayınlandı</time>
            </p>
            <figure class="reader__cover">
              <CoverThumb
                emoji={d.coverEmoji}
                color={d.coverColor}
                image={d.coverImage}
                alt={d.altText ?? d.title}
                ratio="16 / 9"
                big
                loading="eager"
                fetchpriority="high"
                sizes="(max-width: 860px) 100vw, 760px"
              />
            </figure>
          </header>

          <section class="reader__content">
            <Content />
          </section>
        </article>
      </div>

      <section class="story-guide" aria-labelledby="story-guide-title">
        <p class="story-guide__kicker">Masal seçim notu</p>
        <h2 id="story-guide-title">{d.title} kimler için uygun?</h2>
        <p>
          Bu resimli masal MasalNova’da <strong>{ageRange || 'çocuklar'}</strong> için etiketlenmiştir ve birlikte okunduğunda yaklaşık <strong>{d.readingTime} dakika</strong> sürer. Hikâyede {d.themes.length ? d.themes.join(', ') : 'dostluk ve hayal gücü'} temaları öne çıkar.
        </p>
        <dl>
          <div><dt>Yaş</dt><dd>{ageRange || 'Her yaş'}</dd></div>
          <div><dt>Süre</dt><dd>{d.readingTime} dakika</dd></div>
          <div><dt>Konu</dt><dd>{d.themes.slice(0, 3).join(' · ') || primaryCategoryLabel}</dd></div>
        </dl>
        <div class="story-prompts">
          <h3>Okuma sonrası birlikte konuşun</h3>
          <ul>
            <li>Kahramanın yerinde olsaydın hangi kararı verirdin?</li>
            <li>Bu masalda {primaryTheme} neden önemliydi?</li>
          </ul>
        </div>
        <a class="editorial-link" href="/hakkimizda/">MasalNova’nın içerik ve seçim yaklaşımı <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
      </section>

      {d.themes.length > 0 && (
        <div class="themes">
          {d.themes.map((t) => <span class="tag tag-ghost">#{t}</span>)}
        </div>
      )}

      {related.length > 0 && (
        <section class="watch">
          <h2>İzlemek ister misiniz?</h2>
          <p>Bu masalı sevdiyseniz, ilgili videoyu da izleyebilirsiniz.</p>
          <div class="grid grid-3">
            {related.map((v) => <VideoCard video={v!} />)}
          </div>
        </section>
      )}

      {moreStories.length > 0 && (
        <section class="more">
          <h2>Başka Masallar</h2>
          <div class="grid grid-3">
            {moreStories.map((s) => <StoryCard story={s} />)}
          </div>
        </section>
      )}

      <div class="back"><a class="btn btn-ghost" href="/masallar/">← Tüm Masallar</a></div>
    </div>
  </section>
</BaseLayout>

<style>
  .story-page {
    padding: 22px 0 10px;
    background: var(--reader-background);
    color: var(--reader-text-color);
  }
  .crumbs {
    max-width: var(--reader-content-width);
    margin: 0 auto 18px;
    color: var(--reader-text-soft);
    font-weight: 700;
    font-size: .9rem;
  }
  .crumbs a { color: var(--reader-accent); }
  .crumbs a:hover { text-decoration: underline; }
  .crumbs span { opacity: .7; margin: 0 4px; }

  .reader-shell,
  .story-guide,
  .themes,
  .watch,
  .more,
  .back {
    max-width: var(--reader-content-width);
    margin-left: auto;
    margin-right: auto;
  }

  .reader {
    padding: clamp(22px, 5vw, 42px) clamp(18px, 5vw, 24px) 8px;
  }

  .reader__header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--reader-border);
  }

  .reader__eyebrow {
    display: inline-flex;
    margin-bottom: 0.85rem;
    color: var(--reader-accent);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .reader__title {
    margin-bottom: 0.75rem;
    font-family: var(--reader-font-family);
    font-size: calc(var(--reader-font-size) * 1.75);
    line-height: 1.22;
    color: var(--reader-text-color);
  }

  .reader__description {
    margin-bottom: 1rem;
    color: var(--reader-text-soft);
    font-size: 1.06rem;
    line-height: 1.55;
  }

  .reader__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    color: var(--reader-text-soft);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .reader__byline {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    margin-top: .75rem;
    color: var(--reader-text-soft);
    font-size: .76rem;
    font-weight: 700;
  }
  .reader__byline span:first-child { color: var(--reader-accent); }

  .reader__cover {
    margin: 1.5rem 0 0;
    overflow: hidden;
    border: 1px solid var(--reader-border);
    border-radius: 24px;
    background: var(--reader-surface);
    box-shadow: 0 20px 50px rgba(10, 24, 55, 0.14);
  }

  .reader__content {
    color: var(--reader-text-color);
    font-family: var(--reader-font-family);
    font-size: var(--reader-font-size);
    line-height: var(--reader-line-height);
  }

  .reader__content :global(p) {
    margin: 0 0 calc(var(--reader-line-height) * 0.65em);
  }

  .reader__content :global(h2) {
    margin: 2.25em 0 0.75em;
    color: var(--reader-text-color);
    font-family: var(--reader-font-family);
    font-size: calc(var(--reader-font-size) * 1.25);
    line-height: 1.35;
  }

  .reader__content :global(strong) {
    color: var(--reader-accent);
  }

  .story-guide {
    margin-top: 28px;
    padding: clamp(22px, 5vw, 34px);
    border: 1px solid var(--reader-border);
    border-radius: 24px;
    background: var(--reader-surface);
    box-shadow: 0 18px 45px rgba(10,24,55,.08);
  }
  .story-guide__kicker { color: var(--reader-accent); font-size: .72rem; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; }
  .story-guide h2 { margin-top: 7px; color: var(--reader-text-color); font-size: 1.45rem; }
  .story-guide > p:not(.story-guide__kicker) { margin-top: 11px; color: var(--reader-text-soft); }
  .story-guide dl { display: grid; grid-template-columns: repeat(3, 1fr); gap: 9px; margin-top: 18px; }
  .story-guide dl > div { padding: 12px 13px; border: 1px solid var(--reader-border); border-radius: 13px; background: var(--reader-surface-raised); }
  .story-guide dt { color: var(--reader-text-soft); font-size: .68rem; font-weight: 900; letter-spacing: .07em; text-transform: uppercase; }
  .story-guide dd { margin-top: 3px; color: var(--reader-text-color); font-size: .84rem; font-weight: 850; }
  .story-prompts { margin-top: 21px; padding-top: 18px; border-top: 1px solid var(--reader-border); }
  .story-prompts h3 { color: var(--reader-text-color); font-size: 1rem; }
  .story-prompts ul { margin: 9px 0 0 1.2rem; color: var(--reader-text-soft); }
  .editorial-link { display: inline-flex; align-items: center; gap: 6px; margin-top: 18px; color: var(--reader-accent); font-size: .82rem; font-weight: 850; }
  .editorial-link:hover { text-decoration: underline; }

  .themes { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-top: 20px; padding: 0 clamp(18px, 5vw, 24px); }
  .themes .tag { border-color: var(--reader-border); background: var(--reader-surface-raised); color: var(--reader-accent); }

  .watch, .more { margin-top: 40px; }
  .watch h2, .more h2 { color: var(--reader-text-color); font-size: 1.5rem; margin-bottom: 6px; }
  .watch p { color: var(--reader-text-soft); margin-bottom: 16px; }
  .more h2 { margin-bottom: 16px; }
  .back { text-align: center; margin: 34px 0 10px; }
  .back .btn-ghost { color: var(--reader-accent); border-color: var(--reader-border); }
  .back .btn-ghost:hover { background: var(--reader-surface-raised); }

  @media (max-width: 640px) {
    .story-guide dl { grid-template-columns: 1fr; }
  }
</style>
