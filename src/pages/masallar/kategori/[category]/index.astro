---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import StoryCard from '../../../../components/StoryCard.astro';
import { getStories } from '../../../../data/stories';
import { storyCategories } from '../../../../data/taxonomy';

const seoCopy: Record<string, { title: string; description: string; intro: string }> = {
  keloglan: {
    title: 'Keloğlan Masalları Oku – Eğlenceli Türk Masalları',
    description: 'Keloğlan masalları oku: Çocuklar için eğlenceli, öğretici ve ücretsiz Keloğlan hikâyelerini yaşa ve okuma süresine göre keşfet.',
    intro: 'Keloğlan’ın zekâsı, iyi kalbi ve eğlenceli maceralarıyla tanışın. Bu seçkide çocukların hem keyifle okuyacağı hem de güzel değerler keşfedeceği Türkçe Keloğlan masalları bulunur.',
  },
  uyku: {
    title: 'Uyku Masalları Oku – Çocuklar İçin Gece Masalları',
    description: 'Uyku masalları oku: Çocukların gece sakinleşmesine yardımcı olan kısa, huzurlu ve ücretsiz uyku öncesi masalları keşfet.',
    intro: 'Uyku öncesi birlikte geçirilen zamanı sakin bir aile ritüeline dönüştürün. Yumuşak anlatımlı gece masalları, çocukların hayal gücünü beslerken günü huzurlu biçimde tamamlamasına eşlik eder.',
  },
  kisa: {
    title: 'Kısa Masallar Oku – 2-5 Dakikalık Çocuk Masalları',
    description: 'Kısa masallar oku: 2-5 dakikada okunabilen ücretsiz, eğitici ve eğlenceli Türkçe çocuk hikâyelerini hemen keşfet.',
    intro: 'Vaktiniz az olduğunda bile masal keyfinden vazgeçmeyin. Birkaç dakikada okunabilen kısa çocuk masalları; yatmadan önce, yolculukta veya gün içindeki küçük molalarda birlikte okumaya uygundur.',
  },
  egitici: {
    title: 'Eğitici Masallar Oku – Değerler Eğitimi Hikâyeleri',
    description: 'Eğitici masallar oku: Paylaşma, dürüstlük, sabır, dostluk ve sorumluluk temalı ücretsiz çocuk hikâyelerini keşfet.',
    intro: 'Paylaşma, dürüstlük, sabır, dostluk ve sorumluluk gibi değerleri sıcak hikâyelerle keşfedin. Eğitici masallar çocuklara doğrudan öğüt vermek yerine kahramanların seçimleri üzerinden düşünme alanı açar.',
  },
  hayvan: {
    title: 'Hayvan Masalları Oku – Sevimli Çocuk Hikâyeleri',
    description: 'Hayvan masalları oku: Sevimli hayvan kahramanlarla dolu ücretsiz, eğlenceli ve öğretici Türkçe çocuk hikâyelerini keşfet.',
    intro: 'Konuşan hayvanlar, renkli ormanlar ve sıcacık dostluklarla dolu bir dünyaya adım atın. Hayvan masalları çocukların empati, yardımlaşma ve doğa sevgisini hikâyeler aracılığıyla keşfetmesine yardımcı olur.',
  },
};

export async function getStaticPaths() {
  return storyCategories.map((category) => ({ params: { category: category.key }, props: { category } }));
}

const { category } = Astro.props;
const allStories = await getStories();
const stories = allStories.filter((story) => story.data.categories.includes(category.key));
const copy = seoCopy[category.key];
const path = `/masallar/kategori/${category.key}/`;
const canonical = `https://masalnova.com${path}`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: copy.title,
    description: copy.description,
    url: canonical,
    inLanguage: 'tr-TR',
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: stories.length,
      itemListElement: stories.slice(0, 30).map((story, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: `https://masalnova.com/masallar/${story.id}/`,
        name: story.data.title,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: 'https://masalnova.com/' },
      { '@type': 'ListItem', position: 2, name: 'Masallar', item: 'https://masalnova.com/masallar/' },
      { '@type': 'ListItem', position: 3, name: category.label, item: canonical },
    ],
  },
];
---
<BaseLayout title={`${copy.title} | MasalNova`} description={copy.description} path={path} jsonLd={jsonLd} activeNav="masallar">
  <section class="section category-page">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Ana Sayfa</a><span>›</span><a href="/masallar/">Masallar</a><span>›</span><span>{category.label}</span>
      </nav>
      <header class="category-head">
        <span class="category-emoji" aria-hidden="true">{category.emoji}</span>
        <div>
          <p class="kicker">Masal oku · ücretsiz çocuk hikâyeleri</p>
          <h1>{category.label} Oku</h1>
          <p>{copy.intro}</p>
          <strong>{stories.length} masal</strong>
        </div>
      </header>
      <div class="category-links" aria-label="Diğer masal kategorileri">
        {storyCategories.filter((item) => item.key !== category.key).map((item) => (
          <a href={`/masallar/kategori/${item.key}/`}>{item.emoji} {item.label}</a>
        ))}
      </div>
      <div class="grid grid-3 story-grid">
        {stories.map((story) => <StoryCard story={story} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-page { color: #fff; }
  .crumbs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px; color: rgba(255,255,255,.78); font-weight: 700; }
  .crumbs a:hover { color: #fff; text-decoration: underline; }
  .category-head { display: grid; grid-template-columns: auto minmax(0, 1fr); gap: 22px; align-items: start; max-width: 880px; padding: clamp(24px,5vw,44px); border: 1px solid rgba(255,255,255,.24); border-radius: 30px; background: rgba(255,255,255,.1); box-shadow: 0 26px 70px rgba(6,20,60,.22); backdrop-filter: blur(16px); }
  .category-emoji { font-size: clamp(3rem,8vw,5.5rem); line-height: 1; }
  .kicker { margin-bottom: 8px; color: #ffd77a; font-size: .78rem; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; }
  h1 { margin-bottom: 14px; font-size: clamp(2.3rem,6vw,4.7rem); letter-spacing: -.055em; }
  .category-head p:not(.kicker) { max-width: 68ch; color: rgba(255,255,255,.86); font-size: 1.05rem; }
  .category-head strong { display: inline-flex; margin-top: 18px; padding: 7px 13px; border-radius: 999px; background: #fff; color: var(--blue-d); }
  .category-links { display: flex; flex-wrap: wrap; gap: 10px; margin: 26px 0; }
  .category-links a { padding: 9px 14px; border: 1px solid rgba(255,255,255,.25); border-radius: 999px; background: rgba(255,255,255,.12); font-weight: 750; }
  .category-links a:hover { background: rgba(255,255,255,.22); }
  .story-grid :global(.story-card) { box-shadow: 0 22px 55px rgba(6,20,60,.2); }
  @media (max-width: 600px) { .category-head { grid-template-columns: 1fr; } }
</style>
