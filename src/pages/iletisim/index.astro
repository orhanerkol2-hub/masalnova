---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="İletişim — MasalNova Çocuk"
  description="MasalNova Çocuk ile iletişime geçin. Öneri ve görüşleriniz için YouTube kanalımızdan bize ulaşabilirsiniz."
  path="/iletisim/"
  activeNav=""
>
  <section class="section">
    <div class="container">
      <article class="content">
        <h1>İletişim</h1>
        <p>
          Görüş, öneri ve iş birliği talepleriniz için bize ulaşabilirsiniz. Size en kısa
          sürede dönüş yapmaya çalışırız.
        </p>
        <ul class="channels">
          <li>
            <span class="ic">▶</span>
            <div>
              <strong>YouTube</strong>
              <a href="https://www.youtube.com/@masalnovacocuk" target="_blank" rel="noopener">@masalnovacocuk</a>
            </div>
          </li>
          <!-- E-posta adresinizi eklemek isterseniz buraya ekleyebiliriz. -->
        </ul>
        <a class="btn btn-primary" href="https://www.youtube.com/@masalnovacocuk?sub_confirmation=1" target="_blank" rel="noopener">▶ Kanalımıza Abone Ol</a>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .content { background: #fff; color: var(--ink); border-radius: var(--radius-lg); padding: 34px clamp(20px, 5vw, 48px); box-shadow: var(--shadow-lg); border: 1px solid var(--line); max-width: 700px; margin: 0 auto; line-height: 1.8; }
  .content h1 { font-size: clamp(1.7rem, 4vw, 2.4rem); margin-bottom: 14px; }
  .content > p { color: var(--ink-soft); margin-bottom: 18px; }
  .channels { list-style: none; display: grid; gap: 12px; margin-bottom: 22px; }
  .channels li { display: flex; align-items: center; gap: 14px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 14px; padding: 14px 16px; }
  .channels .ic { width: 42px; height: 42px; border-radius: 50%; background: var(--red); color: #fff; display: grid; place-items: center; font-size: 1.1rem; }
  .channels div { display: flex; flex-direction: column; }
  .channels a { color: var(--blue-d); font-weight: 700; }
</style>
