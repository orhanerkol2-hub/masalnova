---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.astro';
import ChoiceCard from '../components/ChoiceCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import StoryCard from '../components/StoryCard.astro';
import FeaturedVideos from '../components/FeaturedVideos.astro';
import CoverThumb from '../components/CoverThumb.astro';
import { getStories, popularStories, todayStory, storyCount } from '../data/stories';
import { featuredVideos, newestVideos } from '../data/videos';
import { ageLabel } from '../data/taxonomy';

const stories = await getStories();
const today = todayStory(stories);
const popular = popularStories(stories, 6);
const latest = stories.slice(0, 12);
const heroStories = [today, ...stories.filter((story) => story.id !== today?.id)].filter(Boolean).slice(0, 5);
const featuredVids = featuredVideos(6);
const newVids = newestVideos(4);

const homeCats = [
  { emoji: '🧒', label: 'Keloğlan Masalları', desc: "Keloğlan'ın sevimli maceraları", href: '/masallar/?tur=keloglan', count: storyCount(stories, 'keloglan'), color: '#ffb01f' },
  { emoji: '🌙', label: 'Uyku Masalları', desc: 'Uyku öncesi sakin masallar', href: '/masallar/?tur=uyku', count: storyCount(stories, 'uyku'), color: '#7b5cff' },
  { emoji: '⏱️', label: 'Kısa Masallar', desc: 'Birkaç dakikada biten masallar', href: '/masallar/?tur=kisa', count: storyCount(stories, 'kisa'), color: '#2f74e8' },
  { emoji: '🎓', label: 'Eğitici Masallar', desc: 'Güzel bir ders veren masallar', href: '/masallar/?tur=egitici', count: storyCount(stories, 'egitici'), color: '#3bb98b' },
  { emoji: '🦊', label: 'Hayvan Masalları', desc: 'Sevimli hayvan kahramanlar', href: '/masallar/?tur=hayvan', count: storyCount(stories, 'hayvan'), color: '#21b6c9' },
  { emoji: '🎈', label: 'Yaşa Göre Masallar', desc: 'Çocuğunuzun yaşına uygun', href: '/masallar/', count: stories.length, color: '#ff8a00' },
];
---
<BaseLayout
  title="MasalNova Çocuk | Masallar ve Çocuk Videoları"
  description="MasalNova Çocuk'ta kısa Türkçe masallar okuyun, çocuk şarkıları ve eğlenceli videoları izleyin. Çocuğunuza uygun içeriği kolayca keşfedin."
  path="/"
  activeNav="home"
>
  <!-- 1) PREMIUM HERO -->
  <section class="premium-hero">
    <div class="hero-glow hero-glow-one" aria-hidden="true"></div>
    <div class="hero-glow hero-glow-two" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">MasalNova Çocuk · Türkçe Masal Kütüphanesi</p>
        <h1>Her akşamı küçük bir masal galasına dönüştürün.</h1>
        <p class="lead">
          Yaşa, süreye ve ruh haline göre seçilmiş yüzlerce masal ve çocuk videosu.
          Okuma deneyimi artık sakin, modern ve aile dostu.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/masallar/">📖 Masal koleksiyonunu aç</a>
          <a class="btn btn-secondary" href="/masal-bul/">✨ Bana masal öner</a>
        </div>
        <div class="hero-search">
          <SearchBox big />
        </div>
        <div class="trust-row" aria-label="MasalNova özellikleri">
          <span>Sakin okuma modu</span>
          <span>Yaşa göre filtre</span>
          <span>Uyku öncesi seçimler</span>
        </div>
      </div>

      <div class="hero-stage" aria-label="Öne çıkan MasalNova içerikleri">
        <div class="hero-carousel" data-hero-carousel>
          {heroStories.map((story, index) => (
            <a
              class="showcase-card"
              href={`/masallar/${story.id}/`}
              data-hero-slide
              data-title={story.data.title}
              data-time={`${story.data.readingTime} dk okuma`}
              aria-hidden={index === 0 ? 'false' : 'true'}
            >
              <div class="showcase-frame">
                <CoverThumb
                  emoji={story.data.coverEmoji}
                  color={story.data.coverColor}
                  image={story.data.coverImage}
                  alt={story.data.altText ?? story.data.title}
                  ratio="4 / 3"
                  big
                />
              </div>
              <div class="showcase-content">
                <span class="badge-type badge-story">📖 Premium Reader</span>
                <h2>{story.data.title}</h2>
                <p>{story.data.shortDescription}</p>
                <span class="showcase-link">Şimdi oku →</span>
              </div>
            </a>
          ))}
          <div class="hero-dots" aria-label="Öne çıkan masalı seç">
            {heroStories.map((story, index) => (
              <button
                type="button"
                data-hero-dot
                aria-label={`${story.data.title} masalını göster`}
                aria-current={index === 0 ? 'true' : 'false'}
              ></button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2) PREMIUM STATS -->
  <section class="premium-strip" aria-label="MasalNova öne çıkan rakamlar">
    <div class="container">
      <div class="strip-panel">
        <div>
          <strong>{stories.length}+</strong>
          <span>Türkçe masal</span>
        </div>
        <div>
          <strong>4 dk</strong>
          <span>Ortalama okuma hissi</span>
        </div>
        <div>
          <strong>3–9</strong>
          <span>Yaşa göre keşif</span>
        </div>
        <div>
          <strong>Reader</strong>
          <span>Telefon & tablet uyumlu</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3) CHOICE CARDS -->
  <section class="section-tight premium-choices">
    <div class="container">
      <div class="grid grid-2">
        <ChoiceCard kind="story" icon="📖" title="Masal Oku" subtitle="Kısa, eğitici ve uyku öncesi masalları premium reader ile keşfedin" href="/masallar/" />
        <ChoiceCard kind="video" icon="🎬" title="Video İzle" subtitle="Çocuk şarkıları, masallar ve eğlenceli videoları güvenli biçimde bulun" href="/videolar/" />
      </div>
    </div>
  </section>

  <!-- NEW STORIES: automatically filled from the newest story files -->
  <section class="section latest-stories" aria-labelledby="latest-stories-title">
    <div class="container">
      <div class="latest-head">
        <div>
          <p class="eyebrow">Yeni keşifler</p>
          <h2 id="latest-stories-title">Masal rafı sürekli büyüyor.</h2>
          <p>Yeni eklenen masallar otomatik olarak en öne gelir. Kartları kaydırarak keşfedin.</p>
        </div>
        <div class="latest-actions" aria-label="Masal kartlarını kaydır">
          <button type="button" class="rail-button" data-rail-prev aria-label="Önceki masalları göster">←</button>
          <button type="button" class="rail-button" data-rail-next aria-label="Sonraki masalları göster">→</button>
        </div>
      </div>
      <div class="story-rail" data-story-rail tabindex="0" aria-label="Yeni eklenen masallar">
        {latest.map((s, index) => (
          <div class="rail-card" data-new={index < 3 ? 'true' : undefined}>
            {index < 3 && <span class="new-ribbon">Yeni</span>}
            <StoryCard story={s} />
          </div>
        ))}
      </div>
      <div class="latest-foot">
        <span>{latest.length} yeni masal · düzenli güncellenir</span>
        <a class="sec-link" href="/masallar/?siralama=yeni">Tüm yeni masallar →</a>
      </div>
    </div>
  </section>

  <!-- 4) STORY CATEGORIES -->
  <section class="section premium-categories">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Koleksiyon</p>
        <div class="sec-head">
          <h2>Her ruh haline uygun masal rafı.</h2>
          <a class="sec-link" href="/masallar/">Tüm Masallar →</a>
        </div>
        <p class="sec-sub">Uyku öncesi sakinlik, kısa molalar, eğitici hikâyeler veya Keloğlan maceraları — hepsi birkaç dokunuş uzağında.</p>
      </div>
      <div class="grid grid-3">
        {homeCats.map((c) => (
          <CategoryCard href={c.href} emoji={c.emoji} label={c.label} desc={c.desc} count={c.count} color={c.color} />
        ))}
      </div>
    </div>
  </section>

  <!-- 5) BUGÜNÜN MASALI -->
  {today && (
    <section class="section daily-feature">
      <div class="container">
        <a class="today-premium" href={`/masallar/${today.id}/`}>
          <div class="today-copy">
            <span class="eyebrow">Bugünün Masalı ✨</span>
            <h2>{today.data.title}</h2>
            <p>{today.data.shortDescription}</p>
            <div class="meta">
              <span class="tag">{today.data.ageGroups[0] ? ageLabel(today.data.ageGroups[0]) : 'Aile okuması'}</span>
              <span class="tag">⏱️ {today.data.readingTime} dk okuma</span>
              <span class="tag">Reader modu</span>
            </div>
            <span class="btn btn-primary">Masalı Oku →</span>
          </div>
          <div class="today-art">
            <CoverThumb emoji={today.data.coverEmoji} color={today.data.coverColor} image={today.data.coverImage} alt={today.data.altText ?? today.data.title} ratio="4 / 3" big />
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- 6) POPÜLER MASALLAR -->
  <section class="section premium-stories">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Editör vitrini</p>
        <div class="sec-head">
          <h2>En sevilen masallar, vitrin kalitesinde.</h2>
          <a class="sec-link" href="/masallar/?siralama=populer">Tümü →</a>
        </div>
      </div>
      <div class="grid grid-3">
        {popular.map((s) => <StoryCard story={s} />)}
      </div>
    </div>
  </section>

  <!-- 7) ÖNE ÇIKAN VIDEOLAR -->
  <FeaturedVideos
    videos={featuredVids}
    title="Sinema hissinde çocuk videoları"
    subtitle="Çocuk şarkıları ve eğlenceli videolar — küçük resme dokun, video açılsın."
    cols={3}
  />

  <!-- 8) CURATED JOURNEY -->
  <section class="section reading-journey">
    <div class="container">
      <div class="journey-card">
        <div>
          <p class="eyebrow">3 adımda akşam ritüeli</p>
          <h2>Seç, oku, sakinleş.</h2>
          <p>MasalNova çocukların dikkatini dağıtmadan, ailelerin hızlı karar vermesine yardım eden sıcak bir keşif alanı olarak tasarlandı.</p>
        </div>
        <div class="journey-steps">
          <span><b>01</b> Yaşa göre filtrele</span>
          <span><b>02</b> Reader modunda oku</span>
          <span><b>03</b> İstersen videoyla devam et</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 9) YENİ VIDEOLAR -->
  <FeaturedVideos
    videos={newVids}
    title="Yeni eklenen videolar"
    moreHref="/videolar/"
    moreLabel="Tüm Videoları Gör"
    cols={4}
  />
</BaseLayout>

<script>
  const rail = document.querySelector<HTMLElement>('[data-story-rail]');
  const previous = document.querySelector<HTMLButtonElement>('[data-rail-prev]');
  const next = document.querySelector<HTMLButtonElement>('[data-rail-next]');

  if (rail && previous && next) {
    const step = () => Math.min(380, rail.clientWidth * 0.82);
    const move = (direction: number) => rail.scrollBy({ left: direction * step(), behavior: 'smooth' });
    previous.addEventListener('click', () => move(-1));
    next.addEventListener('click', () => move(1));

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let timer: number | undefined;
    const stop = () => window.clearInterval(timer);
    const start = () => {
      if (reducedMotion) return;
      stop();
      timer = window.setInterval(() => {
        const atEnd = rail.scrollLeft + rail.clientWidth >= rail.scrollWidth - 12;
        rail.scrollTo({ left: atEnd ? 0 : rail.scrollLeft + step(), behavior: 'smooth' });
      }, 5200);
    };
    rail.addEventListener('pointerenter', stop);
    rail.addEventListener('pointerleave', start);
    rail.addEventListener('focusin', stop);
    rail.addEventListener('focusout', start);
    start();
  }

  const heroCarousel = document.querySelector<HTMLElement>('[data-hero-carousel]');
  const heroSlides = Array.from(document.querySelectorAll<HTMLElement>('[data-hero-slide]'));
  const heroDots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-hero-dot]'));
  if (heroCarousel && heroSlides.length > 1 && heroSlides.length === heroDots.length) {
    let activeHero = 0;
    let heroTimer: number | undefined;
    const reducedHeroMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const showHero = (index: number) => {
      activeHero = (index + heroSlides.length) % heroSlides.length;
      heroSlides.forEach((slide, slideIndex) => slide.setAttribute('aria-hidden', slideIndex === activeHero ? 'false' : 'true'));
      heroDots.forEach((dot, dotIndex) => dot.setAttribute('aria-current', dotIndex === activeHero ? 'true' : 'false'));
    };
    const stopHero = () => window.clearInterval(heroTimer);
    const startHero = () => {
      if (reducedHeroMotion) return;
      stopHero();
      heroTimer = window.setInterval(() => showHero(activeHero + 1), 5800);
    };
    heroDots.forEach((dot, index) => dot.addEventListener('click', () => { showHero(index); startHero(); }));
    heroCarousel.addEventListener('pointerenter', stopHero);
    heroCarousel.addEventListener('pointerleave', startHero);
    heroCarousel.addEventListener('focusin', stopHero);
    heroCarousel.addEventListener('focusout', startHero);
    startHero();
  }
</script>

<style>
  :global(body) {
    background:
      radial-gradient(900px 420px at 82% 4%, rgba(255, 176, 31, 0.2), transparent 60%),
      radial-gradient(900px 520px at 12% 12%, rgba(114, 155, 255, 0.38), transparent 62%),
      linear-gradient(180deg, #081b46 0%, #123a97 42%, #1f57cf 74%, #123a97 100%);
  }

  .premium-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    min-height: 680px;
    color: #fff;
    background:
      linear-gradient(115deg, rgba(8, 27, 70, 0.96), rgba(18, 58, 151, 0.72) 48%, rgba(255, 176, 31, 0.14)),
      url('/background.jpg') center / cover no-repeat;
  }

  .premium-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.2), transparent 34%),
      linear-gradient(180deg, transparent 70%, rgba(8, 27, 70, 0.72));
    z-index: -2;
  }

  .premium-hero::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 170px;
    background: linear-gradient(180deg, transparent, #123a97);
    z-index: -1;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(8px);
    opacity: 0.78;
    pointer-events: none;
    z-index: -1;
  }

  .hero-glow-one {
    width: 360px;
    height: 360px;
    right: 7%;
    top: 10%;
    background: radial-gradient(circle, rgba(255, 176, 31, 0.34), transparent 68%);
  }

  .hero-glow-two {
    width: 420px;
    height: 420px;
    left: -120px;
    bottom: 3%;
    background: radial-gradient(circle, rgba(47, 116, 232, 0.56), transparent 66%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(330px, 0.88fr);
    gap: clamp(36px, 6vw, 80px);
    align-items: center;
    padding-top: clamp(78px, 10vw, 126px);
    padding-bottom: clamp(76px, 10vw, 112px);
  }

  .hero-copy { max-width: 720px; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    color: #ffd77a;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    max-width: 10.8ch;
    margin-bottom: 22px;
    font-size: clamp(3rem, 8vw, 6.95rem);
    line-height: 0.9;
    letter-spacing: -0.08em;
    text-wrap: balance;
    text-shadow: 0 22px 60px rgba(0, 0, 0, 0.34);
  }

  .hero-copy .lead {
    max-width: 58ch;
    margin-bottom: 28px;
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(1.08rem, 2vw, 1.3rem);
    font-weight: 650;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 22px;
  }

  .hero-search {
    max-width: 660px;
    margin-bottom: 18px;
  }

  .hero-search :global(.searchbox) {
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.24);
  }

  .trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .trust-row span {
    padding: 8px 12px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(14px);
  }

  .hero-stage {
    position: relative;
    min-height: 580px;
  }

  .showcase-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.26);
    border-radius: 38px;
    background: linear-gradient(155deg, rgba(255,255,255,0.96), rgba(236, 242, 255, 0.9));
    color: var(--ink);
    box-shadow: 0 38px 110px rgba(0, 0, 0, 0.38);
    transform: rotate(2deg);
  }

  .hero-carousel {
    position: relative;
    min-height: 540px;
  }

  .showcase-card[data-hero-slide] {
    position: absolute;
    inset: 0;
    transition: opacity .65s ease, transform .65s cubic-bezier(.2,.75,.25,1);
  }

  .showcase-card[data-hero-slide][aria-hidden="true"] {
    opacity: 0;
    pointer-events: none;
    transform: translateX(34px) rotate(4deg) scale(.965);
  }

  .showcase-card[data-hero-slide][aria-hidden="false"] {
    opacity: 1;
    transform: translateX(0) rotate(2deg) scale(1);
  }

  .hero-dots {
    position: absolute;
    z-index: 6;
    right: 24px;
    bottom: -28px;
    display: flex;
    gap: 8px;
  }

  .hero-dots button {
    width: 9px;
    height: 9px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(255,255,255,.46);
    box-shadow: 0 5px 16px rgba(0,0,0,.2);
    cursor: pointer;
    transition: width .25s ease, background .25s ease;
  }

  .hero-dots button[aria-current="true"] {
    width: 28px;
    background: #ffd46a;
  }

  .showcase-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(120deg, rgba(255,255,255,0.55), transparent 34%, rgba(255, 176, 31, 0.18));
  }

  .showcase-frame {
    padding: 18px;
    background: linear-gradient(180deg, #fff, #eef4ff);
  }

  .showcase-frame :global(.cover) {
    overflow: hidden;
    border-radius: 28px;
    box-shadow: 0 18px 50px rgba(9, 24, 65, 0.22);
  }

  .showcase-content {
    position: relative;
    z-index: 1;
    padding: 8px 26px 28px;
  }

  .showcase-content h2 {
    margin: 12px 0 8px;
    font-size: clamp(1.45rem, 3vw, 2.05rem);
    letter-spacing: -0.03em;
  }

  .showcase-content p {
    color: var(--ink-soft);
    font-weight: 650;
  }

  .showcase-link {
    display: inline-flex;
    margin-top: 16px;
    color: var(--blue-d);
    font-family: var(--font-display);
    font-weight: 900;
  }

  .showcase-card:hover .showcase-link { transform: translateX(4px); }

  .hero-orbit-card {
    position: absolute;
    z-index: 2;
    width: min(245px, 60%);
    padding: 16px 18px;
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.88);
    color: var(--ink);
    box-shadow: 0 22px 70px rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(18px);
  }

  .hero-orbit-card--top {
    top: 10px;
    right: -12px;
  }

  .hero-orbit-card--bottom {
    left: 22px;
    bottom: 0;
  }

  .mini-kicker {
    display: block;
    margin-bottom: 5px;
    color: var(--blue-d);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-orbit-card strong,
  .hero-orbit-card small {
    display: block;
  }

  .hero-orbit-card strong {
    font-family: var(--font-display);
    font-size: 1.04rem;
    line-height: 1.18;
  }

  .hero-orbit-card small {
    margin-top: 4px;
    color: var(--ink-soft);
    font-weight: 750;
  }

  .premium-strip {
    position: relative;
    z-index: 4;
    margin-top: -54px;
  }

  .strip-panel {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.18);
    box-shadow: 0 32px 90px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(22px);
  }

  .strip-panel div {
    padding: 24px 24px;
    background: rgba(255, 255, 255, 0.93);
  }

  .strip-panel strong,
  .strip-panel span {
    display: block;
  }

  .strip-panel strong {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.6vw, 2.35rem);
    line-height: 1;
  }

  .strip-panel span {
    margin-top: 8px;
    color: var(--ink-soft);
    font-weight: 800;
  }

  .premium-choices {
    padding-top: 42px;
  }

  .latest-stories {
    overflow: hidden;
    padding-top: 54px;
