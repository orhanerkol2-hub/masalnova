---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.astro';
import ChoiceCard from '../components/ChoiceCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import StoryCard from '../components/StoryCard.astro';
import FeaturedVideos from '../components/FeaturedVideos.astro';
import CoverThumb from '../components/CoverThumb.astro';
import { getStories, popularStories, todayStory, storyCount } from '../data/stories';
import { featuredVideos, newestVideos } from '../data/videos';
import { ageLabel } from '../data/taxonomy';

const stories = await getStories();
const today = todayStory(stories);
const popular = popularStories(stories, 6);
const latest = stories.slice(0, 12);
const heroStories = [today, ...stories.filter((story) => story.id !== today?.id)].filter(Boolean).slice(0, 5);
const featuredVids = featuredVideos(6);
const newVids = newestVideos(4);

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://masalnova.com/#masal-koleksiyonu',
  name: 'Masal Oku – Uyku Masalları ve Çocuk Hikâyeleri',
  description: 'Çocuklar için ücretsiz Türkçe uyku masalları, eğitici masallar, kısa masallar ve Keloğlan hikâyeleri.',
  url: 'https://masalnova.com/',
  inLanguage: 'tr-TR',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: latest.length,
    itemListElement: latest.map((story, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `https://masalnova.com/masallar/${story.id}/`,
      name: story.data.title,
    })),
  },
};

const homeCats = [
  { emoji: '🧒', label: 'Keloğlan Masalları', desc: "Keloğlan'ın sevimli maceraları", href: '/masallar/kategori/keloglan/', count: storyCount(stories, 'keloglan'), color: '#ffb01f' },
  { emoji: '🌙', label: 'Uyku Masalları', desc: 'Uyku öncesi sakin masallar', href: '/masallar/kategori/uyku/', count: storyCount(stories, 'uyku'), color: '#7b5cff' },
  { emoji: '⏱️', label: 'Kısa Masallar', desc: 'Birkaç dakikada biten masallar', href: '/masallar/kategori/kisa/', count: storyCount(stories, 'kisa'), color: '#2f74e8' },
  { emoji: '🎓', label: 'Eğitici Masallar', desc: 'Güzel bir ders veren masallar', href: '/masallar/kategori/egitici/', count: storyCount(stories, 'egitici'), color: '#3bb98b' },
  { emoji: '🦊', label: 'Hayvan Masalları', desc: 'Sevimli hayvan kahramanlar', href: '/masallar/kategori/hayvan/', count: storyCount(stories, 'hayvan'), color: '#21b6c9' },
  { emoji: '🎈', label: 'Yaşa Göre Masallar', desc: 'Çocuğunuzun yaşına uygun', href: '/masallar/', count: stories.length, color: '#ff8a00' },
];
---
<BaseLayout
  title="Masal Oku – Uyku Masalları ve Çocuk Hikâyeleri | MasalNova"
  description="Masal oku: Çocuklar için ücretsiz uyku masalları, kısa ve eğitici hikâyeler, hayvan ve Keloğlan masalları. Yaşa ve okuma süresine göre keşfet."
  path="/"
  jsonLd={homeJsonLd}
  activeNav="home"
>
  <!-- 1) PREMIUM HERO -->
  <section class="premium-hero">
    <div class="hero-glow hero-glow-one" aria-hidden="true"></div>
    <div class="hero-glow hero-glow-two" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">MasalNova Çocuk · Türkçe Masal Kütüphanesi</p>
        <h1>Masal oku, her akşamı küçük bir masal galasına dönüştür.</h1>
        <p class="lead">
          Yaşa, süreye ve ruh haline göre seçilmiş yüzlerce masal ve çocuk videosu.
          Okuma deneyimi artık sakin, modern ve aile dostu.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/masallar/">📖 Masal koleksiyonunu aç</a>
          <a class="btn btn-secondary" href="/masal-bul/">✨ Bana masal öner</a>
        </div>
        <div class="hero-search">
          <SearchBox big />
        </div>
        <div class="trust-row" aria-label="MasalNova özellikleri">
          <span>Sakin okuma modu</span>
          <span>Yaşa göre filtre</span>
          <span>Uyku öncesi seçimler</span>
        </div>
      </div>

      <div class="hero-stage" aria-label="Öne çıkan MasalNova içerikleri">
        <div class="hero-carousel" data-hero-carousel>
          {heroStories.map((story, index) => (
            <a
              class="showcase-card"
              href={`/masallar/${story.id}/`}
              data-hero-slide
              data-title={story.data.title}
              data-time={`${story.data.readingTime} dk okuma`}
              aria-hidden={index === 0 ? 'false' : 'true'}
            >
              <div class="showcase-frame">
                <CoverThumb
                  emoji={story.data.coverEmoji}
                  color={story.data.coverColor}
                  image={story.data.coverImage}
                  alt={story.data.altText ?? story.data.title}
                  ratio="4 / 3"
                  big
                />
              </div>
              <div class="showcase-content">
                <span class="badge-type badge-story">📖 Premium Reader</span>
                <h2>{story.data.title}</h2>
                <p>{story.data.shortDescription}</p>
                <span class="showcase-link">Şimdi oku →</span>
              </div>
            </a>
          ))}
          <div class="hero-dots" aria-label="Öne çıkan masalı seç">
            {heroStories.map((story, index) => (
              <button
                type="button"
                data-hero-dot
                aria-label={`${story.data.title} masalını göster`}
                aria-current={index === 0 ? 'true' : 'false'}
              ></button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2) PREMIUM STATS -->
  <section class="premium-strip" aria-label="MasalNova öne çıkan rakamlar">
    <div class="container">
      <div class="strip-panel">
        <div>
          <strong>{stories.length}+</strong>
          <span>Türkçe masal</span>
        </div>
        <div>
          <strong>4 dk</strong>
          <span>Ortalama okuma hissi</span>
        </div>
        <div>
          <strong>3–9</strong>
          <span>Yaşa göre keşif</span>
        </div>
        <div>
          <strong>Reader</strong>
          <span>Telefon & tablet uyumlu</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3) CHOICE CARDS -->
  <section class="section-tight premium-choices">
    <div class="container">
      <div class="grid grid-2">
        <ChoiceCard kind="story" icon="📖" title="Masal Oku" subtitle="Kısa, eğitici ve uyku öncesi masalları premium reader ile keşfedin" href="/masallar/" />
        <ChoiceCard kind="video" icon="🎬" title="Video İzle" subtitle="Çocuk şarkıları, masallar ve eğlenceli videoları güvenli biçimde bulun" href="/videolar/" />
      </div>
    </div>
  </section>

  <!-- NEW STORIES: automatically filled from the newest story files -->
  <section class="section latest-stories" aria-labelledby="latest-stories-title">
    <div class="container swipe-layout">
      <div class="swipe-intro">
        <p class="eyebrow">Kaydırarak keşfet</p>
        <h2 id="latest-stories-title">Bir masal seç. Kaydır. Hikâyeye dal.</h2>
        <p>Yeni masalları kart destesi gibi keşfet. Kartı sürükle, ok tuşlarını kullan veya doğrudan okumaya başla.</p>
        <div class="swipe-progress" aria-live="polite">
          <strong data-swipe-current>1</strong>
          <span>/ {latest.length} yeni masal</span>
        </div>
        <p class="swipe-hint">Sola kaydır: sonraki · Sağa kaydır: önceki</p>
        <a class="sec-link" href="/masallar/?siralama=yeni">Tüm yeni masalları gör →</a>
      </div>

      <div class="swipe-deck">
        <div
          class="swipe-stack"
          data-story-swipe
          tabindex="0"
          role="group"
          aria-roledescription="kaydırılabilir masal kartları"
          aria-label="Yeni eklenen masalları keşfet"
        >
          {latest.map((s, index) => (
            <div
              class="swipe-card"
              data-swipe-card
              data-card-title={s.data.title}
              data-card-href={`/masallar/${s.id}/`}
              data-state={index === 0 ? 'active' : index === 1 ? 'next' : index === 2 ? 'queued' : 'hidden'}
              aria-hidden={index === 0 ? 'false' : 'true'}
              inert={index === 0 ? undefined : true}
            >
              <span class="swipe-stamp swipe-stamp--previous" aria-hidden="true">ÖNCEKİ</span>
              <span class="swipe-stamp swipe-stamp--next" aria-hidden="true">SONRAKİ</span>
              {index < 3 && <span class="new-ribbon">Yeni</span>}
              <StoryCard story={s} />
            </div>
          ))}
        </div>

        <div class="swipe-actions" aria-label="Masal kartlarını kontrol et">
          <button type="button" class="swipe-button swipe-button--previous" data-swipe-prev aria-label="Önceki masalı göster">
            <span aria-hidden="true">←</span>
            <small>Önceki</small>
          </button>
          <a class="swipe-open" data-swipe-open href={`/masallar/${latest[0]?.id}/`}>Bu masalı oku</a>
          <button type="button" class="swipe-button swipe-button--next" data-swipe-next aria-label="Sonraki masalı göster">
            <span aria-hidden="true">→</span>
            <small>Sonraki</small>
          </button>
        </div>
        <p class="sr-only" data-swipe-status aria-live="polite">{latest[0]?.data.title} gösteriliyor.</p>
      </div>
    </div>
  </section>

  <!-- 4) STORY CATEGORIES -->
  <section class="section premium-categories">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Koleksiyon</p>
        <div class="sec-head">
          <h2>Her ruh haline uygun masal rafı.</h2>
          <a class="sec-link" href="/masallar/">Tüm Masallar →</a>
        </div>
        <p class="sec-sub">Uyku öncesi sakinlik, kısa molalar, eğitici hikâyeler veya Keloğlan maceraları — hepsi birkaç dokunuş uzağında.</p>
      </div>
      <div class="grid grid-3">
        {homeCats.map((c) => (
          <CategoryCard href={c.href} emoji={c.emoji} label={c.label} desc={c.desc} count={c.count} color={c.color} />
        ))}
      </div>
    </div>
  </section>

  <!-- 5) BUGÜNÜN MASALI -->
  {today && (
    <section class="section daily-feature">
      <div class="container">
        <a class="today-premium" href={`/masallar/${today.id}/`}>
          <div class="today-copy">
            <span class="eyebrow">Bugünün Masalı ✨</span>
            <h2>{today.data.title}</h2>
            <p>{today.data.shortDescription}</p>
            <div class="meta">
              <span class="tag">{today.data.ageGroups[0] ? ageLabel(today.data.ageGroups[0]) : 'Aile okuması'}</span>
              <span class="tag">⏱️ {today.data.readingTime} dk okuma</span>
              <span class="tag">Reader modu</span>
            </div>
            <span class="btn btn-primary">Masalı Oku →</span>
          </div>
          <div class="today-art">
            <CoverThumb emoji={today.data.coverEmoji} color={today.data.coverColor} image={today.data.coverImage} alt={today.data.altText ?? today.data.title} ratio="4 / 3" big />
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- 6) POPÜLER MASALLAR -->
  <section class="section premium-stories">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Editör vitrini</p>
        <div class="sec-head">
          <h2>En sevilen masallar, vitrin kalitesinde.</h2>
          <a class="sec-link" href="/masallar/?siralama=populer">Tümü →</a>
        </div>
      </div>
      <div class="grid grid-3">
        {popular.map((s) => <StoryCard story={s} />)}
      </div>
    </div>
  </section>

  <!-- 7) ÖNE ÇIKAN VIDEOLAR -->
  <FeaturedVideos
    videos={featuredVids}
    title="Sinema hissinde çocuk videoları"
    subtitle="Çocuk şarkıları ve eğlenceli videolar — küçük resme dokun, video açılsın."
    cols={3}
  />

  <!-- 8) CURATED JOURNEY -->
  <section class="section reading-journey">
    <div class="container">
      <div class="journey-card">
        <div>
          <p class="eyebrow">3 adımda akşam ritüeli</p>
          <h2>Seç, oku, sakinleş.</h2>
          <p>MasalNova çocukların dikkatini dağıtmadan, ailelerin hızlı karar vermesine yardım eden sıcak bir keşif alanı olarak tasarlandı.</p>
        </div>
        <div class="journey-steps">
          <span><b>01</b> Yaşa göre filtrele</span>
          <span><b>02</b> Reader modunda oku</span>
          <span><b>03</b> İstersen videoyla devam et</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 9) YENİ VIDEOLAR -->
  <FeaturedVideos
    videos={newVids}
    title="Yeni eklenen videolar"
    moreHref="/videolar/"
    moreLabel="Tüm Videoları Gör"
    cols={4}
  />
</BaseLayout>

<script>
  const swipeStack = document.querySelector<HTMLElement>('[data-story-swipe]');
  const swipeCards = Array.from(document.querySelectorAll<HTMLElement>('[data-swipe-card]'));
  const swipePrevious = document.querySelector<HTMLButtonElement>('[data-swipe-prev]');
  const swipeNext = document.querySelector<HTMLButtonElement>('[data-swipe-next]');
  const swipeOpen = document.querySelector<HTMLAnchorElement>('[data-swipe-open]');
  const swipeCurrent = document.querySelector<HTMLElement>('[data-swipe-current]');
  const swipeStatus = document.querySelector<HTMLElement>('[data-swipe-status]');

  if (swipeStack && swipeCards.length && swipePrevious && swipeNext && swipeOpen) {
    let activeIndex = 0;
    let startX = 0;
    let dragX = 0;
    let pointerId: number | null = null;
    let moving = false;
    let dragged = false;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const indexAt = (offset: number) => (activeIndex + offset + swipeCards.length) % swipeCards.length;
    const activeCard = () => swipeCards[activeIndex];

    const renderSwipe = () => {
      const nextIndex = indexAt(1);
      const queuedIndex = indexAt(2);
      swipeCards.forEach((card, index) => {
        const state = index === activeIndex ? 'active' : index === nextIndex ? 'next' : index === queuedIndex ? 'queued' : 'hidden';
        card.dataset.state = state;
        card.setAttribute('aria-hidden', state === 'active' ? 'false' : 'true');
        card.toggleAttribute('inert', state !== 'active');
        card.style.removeProperty('--drag-x');
        card.style.removeProperty('--drag-rotate');
        card.style.removeProperty('--drag-opacity');
      });

      const card = activeCard();
      const title = card.dataset.cardTitle ?? 'Masal';
      const href = card.dataset.cardHref ?? '/masallar/';
      swipeOpen.href = href;
      swipeOpen.setAttribute('aria-label', `${title} masalını oku`);
      if (swipeCurrent) swipeCurrent.textContent = String(activeIndex + 1);
      if (swipeStatus) swipeStatus.textContent = `${title} gösteriliyor.`;
      moving = false;
    };

    const resetDrag = () => {
      const card = activeCard();
      card.style.setProperty('--drag-x', '0px');
      card.style.setProperty('--drag-rotate', '0deg');
      card.style.setProperty('--drag-opacity', '1');
    };

    const moveSwipe = (direction: number) => {
      if (moving) return;
      moving = true;
      const card = activeCard();
      const exitX = direction > 0 ? '-120vw' : '120vw';
      const exitRotation = direction > 0 ? '-18deg' : '18deg';
      card.style.setProperty('--drag-x', exitX);
      card.style.setProperty('--drag-rotate', exitRotation);
      card.style.setProperty('--drag-opacity', '0');

      window.setTimeout(() => {
        activeIndex = indexAt(direction);
        renderSwipe();
      }, reducedMotion ? 0 : 280);
    };

    swipePrevious.addEventListener('click', () => moveSwipe(-1));
    swipeNext.addEventListener('click', () => moveSwipe(1));

    swipeStack.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') { event.preventDefault(); moveSwipe(-1); }
      if (event.key === 'ArrowRight') { event.preventDefault(); moveSwipe(1); }
      if (event.key === 'Enter') { event.preventDefault(); swipeOpen.click(); }
    });

    swipeStack.addEventListener('pointerdown', (event) => {
      if (moving || event.button !== 0) return;
      pointerId = event.pointerId;
      startX = event.clientX;
      dragX = 0;
      dragged = false;
      swipeStack.setPointerCapture(pointerId);
      swipeStack.dataset.dragging = 'true';
    });

    swipeStack.addEventListener('pointermove', (event) => {
      if (pointerId !== event.pointerId || moving) return;
      dragX = event.clientX - startX;
      dragged ||= Math.abs(dragX) > 8;
      const card = activeCard();
      card.style.setProperty('--drag-x', `${dragX}px`);
      card.style.setProperty('--drag-rotate', `${Math.max(-12, Math.min(12, dragX / 22))}deg`);
      card.style.setProperty('--drag-opacity', String(Math.max(.78, 1 - Math.abs(dragX) / 900)));
      swipeStack.style.setProperty('--swipe-direction', String(Math.max(-1, Math.min(1, dragX / 100))));
    });

    const finishDrag = (event: PointerEvent) => {
      if (pointerId !== event.pointerId) return;
      if (swipeStack.hasPointerCapture(pointerId)) swipeStack.releasePointerCapture(pointerId);
      pointerId = null;
      swipeStack.dataset.dragging = 'false';
      swipeStack.style.setProperty('--swipe-direction', '0');
      if (Math.abs(dragX) >= 90) moveSwipe(dragX < 0 ? 1 : -1);
      else resetDrag();
    };

    swipeStack.addEventListener('pointerup', finishDrag);
    swipeStack.addEventListener('pointercancel', finishDrag);
    swipeStack.addEventListener('click', (event) => {
      if (dragged) event.preventDefault();
      dragged = false;
    }, true);

    renderSwipe();
  }

  const heroCarousel = document.querySelector<HTMLElement>('[data-hero-carousel]');
  const heroSlides = Array.from(document.querySelectorAll<HTMLElement>('[data-hero-slide]'));
  const heroDots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-hero-dot]'));
  if (heroCarousel && heroSlides.length > 1 && heroSlides.length === heroDots.length) {
    let activeHero = 0;
    let heroTimer: number | undefined;
    const reducedHeroMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const showHero = (index: number) => {
      activeHero = (index + heroSlides.length) % heroSlides.length;
      heroSlides.forEach((slide, slideIndex) => slide.setAttribute('aria-hidden', slideIndex === activeHero ? 'false' : 'true'));
      heroDots.forEach((dot, dotIndex) => dot.setAttribute('aria-current', dotIndex === activeHero ? 'true' : 'false'));
    };
    const stopHero = () => window.clearInterval(heroTimer);
    const startHero = () => {
      if (reducedHeroMotion) return;
      stopHero();
      heroTimer = window.setInterval(() => showHero(activeHero + 1), 5800);
    };
    heroDots.forEach((dot, index) => dot.addEventListener('click', () => { showHero(index); startHero(); }));
    heroCarousel.addEventListener('pointerenter', stopHero);
    heroCarousel.addEventListener('pointerleave', startHero);
    heroCarousel.addEventListener('focusin', stopHero);
    heroCarousel.addEventListener('focusout', startHero);
    startHero();
  }
</script>

<style>
  :global(body) {
    background:
      radial-gradient(900px 420px at 82% 4%, rgba(255, 176, 31, 0.2), transparent 60%),
      radial-gradient(900px 520px at 12% 12%, rgba(114, 155, 255, 0.38), transparent 62%),
      linear-gradient(180deg, #081b46 0%, #123a97 42%, #1f57cf 74%, #123a97 100%);
  }

  .premium-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    min-height: 680px;
    color: #fff;
    background:
      linear-gradient(115deg, rgba(8, 27, 70, 0.96), rgba(18, 58, 151, 0.72) 48%, rgba(255, 176, 31, 0.14)),
      url('/background.jpg') center / cover no-repeat;
  }

  .premium-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.2), transparent 34%),
      linear-gradient(180deg, transparent 70%, rgba(8, 27, 70, 0.72));
    z-index: -2;
  }

  .premium-hero::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 170px;
    background: linear-gradient(180deg, transparent, #123a97);
    z-index: -1;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(8px);
    opacity: 0.78;
    pointer-events: none;
    z-index: -1;
  }

  .hero-glow-one {
    width: 360px;
    height: 360px;
    right: 7%;
    top: 10%;
    background: radial-gradient(circle, rgba(255, 176, 31, 0.34), transparent 68%);
  }

  .hero-glow-two {
    width: 420px;
    height: 420px;
    left: -120px;
    bottom: 3%;
    background: radial-gradient(circle, rgba(47, 116, 232, 0.56), transparent 66%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(330px, 0.88fr);
    gap: clamp(36px, 6vw, 80px);
    align-items: center;
    padding-top: clamp(78px, 10vw, 126px);
    padding-bottom: clamp(76px, 10vw, 112px);
  }

  .hero-copy { max-width: 720px; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    color: #ffd77a;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    max-width: 10.8ch;
    margin-bottom: 22px;
    font-size: clamp(3rem, 8vw, 6.95rem);
    line-height: 0.9;
    letter-spacing: -0.08em;
    text-wrap: balance;
    text-shadow: 0 22px 60px rgba(0, 0, 0, 0.34);
  }

  .hero-copy .lead {
    max-width: 58ch;
    margin-bottom: 28px;
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(1.08rem, 2vw, 1.3rem);
    font-weight: 650;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 22px;
  }

  .hero-search {
    max-width: 660px;
    margin-bottom: 18px;
  }

  .hero-search :global(.searchbox) {
