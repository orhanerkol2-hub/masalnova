---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getStories, popularStories } from '../data/stories';
import { featuredVideos } from '../data/videos';
import {
  ageLabel,
  durationBucketForMinutes,
  storyCategoryLabel,
  videoCategoryLabel,
} from '../data/taxonomy';

const stories = await getStories();
const bestStoryIds = [
  'kirmizi-baslikli-kiz',
  'pamuk-prenses-ve-yedi-cuceler',
  'kulkedisi',
  'pinokyo',
  'uyuyan-guzel',
  'keloglan-dev',
];

const deckStoryIds = [
  ...bestStoryIds,
  'alice',
];

const storiesWithCoversForIds = (ids: string[]) => ids.flatMap((id) => {
  const story = stories.find((candidate) => candidate.id === id);
  return story?.data.coverImage ? [story] : [];
});

const bestStories = storiesWithCoversForIds(bestStoryIds);
const deckStories = storiesWithCoversForIds(deckStoryIds);

const continueStories = [...bestStories, ...deckStories, ...popularStories(stories, 12)]
  .filter((story, index, list) => list.findIndex((candidate) => candidate.id === story.id) === index)
  .filter((story) => story.data.coverImage)
  .slice(0, 10);
const videos = featuredVideos(6);

const moodForStory = (story: (typeof stories)[number]) => {
  const signals = [...story.data.categories, ...story.data.themes].join(' ').toLocaleLowerCase('tr');
  if (/(uyku|sakin|huzur|sabır|sabir)/.test(signals)) return 'sakin';
  if (/(macera|cesaret|keşif|kesif|kahraman)/.test(signals)) return 'macera';
  return 'neseli';
};

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://masalnova.com/#masal-koleksiyonu',
  name: 'Masal Oku – Uyku Masalları ve Çocuk Hikâyeleri',
  description: 'Çocuklar için ücretsiz Türkçe uyku masalları, eğitici masallar, kısa masallar ve videolar.',
  url: 'https://masalnova.com/',
  inLanguage: 'tr-TR',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: bestStories.length,
    itemListElement: bestStories.map((story, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `https://masalnova.com/masallar/${story.id}/`,
      name: story.data.title,
    })),
  },
};
---

<BaseLayout
  title="Masal Oku – Uyku Masalları ve Çocuk Hikâyeleri | MasalNova"
  description="Masal oku: Çocuklar için ücretsiz uyku masalları, kısa ve eğitici hikâyeler ile güvenli çocuk videoları. Yaşa, süreye ve ruh haline göre keşfet."
  path="/"
  image={bestStories[0]?.data.coverImage}
  imageAlt={bestStories[0] ? `${bestStories[0].data.title} resimli masal kapağı` : 'MasalNova çocuk masalları'}
  preloadImage={bestStories[0]?.data.coverImage}
  jsonLd={homeJsonLd}
  activeNav="home"
>
  <div class="app-home">
    <section class="tonight" aria-labelledby="tonight-title">
      <div class="tonight-heading">
        <div>
          <p class="app-kicker"><i class="ph ph-moon-stars" aria-hidden="true"></i> Masal oku · Bu akşam için</p>
          <h1 id="tonight-title">Bu gece hangi masalı okuyalım?</h1>
          <p class="tonight-intro">Ücretsiz Türkçe uyku masalları ve çocuk hikâyeleri arasından yaşa, süreye ve ruh hâline göre seçim yapın.</p>
        </div>
        <a class="discover-link" href="/masallar/">
          Tüm masallar <i class="ph ph-arrow-right" aria-hidden="true"></i>
        </a>
      </div>

      <div class="preference-bar" aria-label="Masal tercihleri">
        <label class="preference-chip">
          <i class="ph ph-child" aria-hidden="true"></i>
          <span class="sr-only">Yaş</span>
          <select data-story-preference="age" aria-label="Yaş seç">
            <option value="">Her yaş</option>
            <option value="3-5">3–5 yaş</option>
            <option value="5-7">5–7 yaş</option>
            <option value="7-9">7–9 yaş</option>
          </select>
          <i class="ph ph-caret-down" aria-hidden="true"></i>
        </label>
        <label class="preference-chip">
          <i class="ph ph-clock" aria-hidden="true"></i>
          <span class="sr-only">Süre</span>
          <select data-story-preference="duration" aria-label="Okuma süresi seç">
            <option value="">Her süre</option>
            <option value="kisa">2 dakika</option>
            <option value="orta">5 dakika</option>
            <option value="uzun">Uzun masal</option>
          </select>
          <i class="ph ph-caret-down" aria-hidden="true"></i>
        </label>
        <label class="preference-chip">
          <i class="ph ph-sparkle" aria-hidden="true"></i>
          <span class="sr-only">Ruh hali</span>
          <select data-story-preference="mood" aria-label="Ruh hali seç">
            <option value="">Her ruh hali</option>
            <option value="sakin">Sakin</option>
            <option value="neseli">Neşeli</option>
            <option value="macera">Macera</option>
          </select>
          <i class="ph ph-caret-down" aria-hidden="true"></i>
        </label>
      </div>

      <div class="story-deck-shell">
        <div
          class="story-deck"
          data-story-deck
          tabindex="0"
          role="group"
          aria-roledescription="kaydırılabilir masal destesi"
          aria-label="Bu akşamın masal önerileri"
        >
          {deckStories.map((story, index) => {
            const d = story.data;
            const primaryCategory = d.categories[0] ? storyCategoryLabel(d.categories[0]) : 'Masal';
            return (
              <article
                class="deck-card"
                data-deck-card
                data-story-id={story.id}
                data-age={d.ageGroups.join(' ')}
                data-duration={durationBucketForMinutes(d.readingTime)}
                data-mood={moodForStory(story)}
                data-state={index === 0 ? 'active' : index === 1 ? 'next' : 'hidden'}
                aria-hidden={index === 0 ? 'false' : 'true'}
              >
                <div class="deck-cover">
                  <img
                    src={d.coverImage}
                    alt={d.altText ?? d.title}
                    width="900"
                    height="680"
                    loading={index < 2 ? 'eager' : 'lazy'}
                    decoding="async"
                    fetchpriority={index === 0 ? 'high' : 'auto'}
                    sizes="(max-width: 720px) calc(100vw - 32px), (max-width: 1100px) 55vw, 520px"
                  />
                  <span class="story-kind"><i class="ph ph-book-open-text" aria-hidden="true"></i> {primaryCategory}</span>
                  <button
                    class="favorite-button"
                    type="button"
                    data-favorite-story={story.id}
                    data-favorite-title={d.title}
                    aria-label={`${d.title} masalını favorilere ekle`}
                    aria-pressed="false"
                  >
                    <i class="ph ph-heart" aria-hidden="true"></i>
                  </button>
                  <div class="deck-gradient" aria-hidden="true"></div>
                </div>
                <div class="deck-copy">
                  <div class="deck-copy-top">
                    <p class="deck-eyebrow">MasalNova seçkisi</p>
                    <h2>{d.title}</h2>
                    <p class="deck-description">{d.shortDescription}</p>
                  </div>
                  <div class="story-meta" aria-label="Masal bilgileri">
                    {d.ageGroups[0] && <span><i class="ph ph-child" aria-hidden="true"></i>{ageLabel(d.ageGroups[0])}</span>}
                    <span><i class="ph ph-clock" aria-hidden="true"></i>{d.readingTime} dk</span>
                    <span><i class="ph ph-moon-stars" aria-hidden="true"></i>{moodForStory(story) === 'sakin' ? 'Sakin' : moodForStory(story) === 'macera' ? 'Macera' : 'Neşeli'}</span>
                  </div>
                  <a class="start-story" href={`/masallar/${story.id}/`}>
                    <i class="ph-fill ph-play" aria-hidden="true"></i>
                    Masalı başlat
                  </a>
                  <p class="online-note"><i class="ph ph-shield-check" aria-hidden="true"></i> Çevrimiçi okuma · Metin cihazda saklanmaz</p>
                </div>
              </article>
            );
          })}
        </div>

        <div class="deck-controls" aria-label="Masal kartlarını değiştir">
          <button type="button" data-deck-prev aria-label="Önceki masal">
            <i class="ph ph-arrow-left" aria-hidden="true"></i>
          </button>
          <p><strong data-deck-position>1</strong><span> / {deckStories.length}</span> · Kartı kaydır</p>
          <button type="button" data-deck-next aria-label="Sonraki masal">
            <i class="ph ph-arrow-right" aria-hidden="true"></i>
          </button>
        </div>
      </div>
    </section>

    <aside class="native-ad" aria-label="Reklam alanı">
      <div>
        <span>Reklam</span>
        <p>Aileler için seçilmiş içerik</p>
      </div>
      <i class="ph ph-sparkle" aria-hidden="true"></i>
    </aside>

    <section
      class="continue-section"
      id="kitapligim"
      aria-labelledby="continue-title"
      data-smart-story-section
      data-mode="best"
    >
      <div class="section-heading">
        <div>
          <p class="app-kicker" data-smart-story-kicker><i class="ph ph-sparkle" aria-hidden="true"></i> <span data-smart-story-kicker-label>Klasik masallar</span></p>
          <h2 id="continue-title" data-smart-story-title>En sevilen klasik çocuk masalları</h2>
          <p data-smart-story-intro>Kırmızı Başlıklı Kız, Pamuk Prenses, Külkedisi, Pinokyo, Uyuyan Güzel ve Keloğlan gibi kuşakların sevdiği Türkçe klasik masalları keşfet.</p>
        </div>
        <a href="/masallar/" data-smart-story-link><span data-smart-story-link-label>Tüm masallar</span> <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
      </div>

      <div class="continue-grid" data-continue-grid>
        {continueStories.map((story, index) => (
          <a
            class="continue-card"
            href={`/masallar/${story.id}/`}
            data-continue-story={story.id}
            data-fallback-index={index}
            data-featured-story={index < bestStories.length ? 'true' : 'false'}
          >
            <img src={story.data.coverImage} alt={story.data.altText ?? `${story.data.title} masal kapağı`} width="320" height="220" loading="lazy" />
            <div>
              <span>{story.data.readingTime} dk okuma</span>
              <h3>{story.data.title}</h3>
              <div class="progress-track" aria-hidden="true"><span data-story-progress></span></div>
              <p data-progress-label>Masalı oku</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="video-section" aria-labelledby="video-title">
      <div class="section-heading">
        <div>
          <p class="app-kicker"><i class="ph ph-film-slate" aria-hidden="true"></i> İzle</p>
          <h2 id="video-title">Masalları video olarak da keşfet</h2>
          <p>Şarkılar, animasyonlar ve masal videoları — her biri doğrudan kendi sayfasına açılır.</p>
        </div>
        <a href="/videolar/">Tüm videolar <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
      </div>

      <div class="video-rail">
        {videos.map((video, index) => (
          <a class="video-tile" href={`/videolar/${video.slug}/`} aria-label={`${video.title} videosunu aç`}>
            <div class="video-visual">
              <img
                src={video.thumbnailUrl}
                alt={`${video.title} video küçük resmi`}
                width="640"
                height="360"
                loading={index < 2 ? 'eager' : 'lazy'}
              />
              <span class="video-badge"><i class="ph-fill ph-play" aria-hidden="true"></i> Video</span>
              <span class="video-play" aria-hidden="true"><i class="ph-fill ph-play"></i></span>
            </div>
            <div class="video-copy">
              <span>{video.categories[0] ? videoCategoryLabel(video.categories[0]) : 'MasalNova Video'}</span>
              <h3>{video.title}</h3>
              <p>Şimdi izle <i class="ph ph-arrow-up-right" aria-hidden="true"></i></p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="library-section" aria-labelledby="favorites-title">
      <div class="section-heading compact-heading">
        <div>
          <p class="app-kicker"><i class="ph ph-heart" aria-hidden="true"></i> Favoriler</p>
          <h2 id="favorites-title">Kaydettiğin masallar</h2>
        </div>
      </div>
      <div class="favorite-grid" data-favorite-grid>
        {deckStories.map((story) => (
          <a class="favorite-card" href={`/masallar/${story.id}/`} data-favorite-card={story.id} hidden>
            <img src={story.data.coverImage} alt="" width="280" height="190" loading="lazy" />
            <div><span>{story.data.readingTime} dk</span><h3>{story.data.title}</h3></div>
          </a>
        ))}
      </div>
      <div class="empty-library" data-empty-library>
        <i class="ph ph-heart-straight" aria-hidden="true"></i>
        <div><h3>Favorilerin burada görünür</h3><p>Bir masal kartındaki kalbe dokunman yeterli.</p></div>
      </div>
    </section>

    <section class="settings-section" id="ayarlar" aria-labelledby="settings-title">
      <div class="settings-copy">
        <p class="app-kicker"><i class="ph ph-gear" aria-hidden="true"></i> Ayarlar</p>
        <h2 id="settings-title">Basit, özel ve hesapsız.</h2>
        <p>Favoriler, filtreler ve okuma yüzdesi yalnızca bu cihazda küçük kimlikler olarak tutulur. Masal metinleri cihazına kaydedilmez.</p>
      </div>
      <div class="settings-actions">
        <button type="button" class="clear-data" data-open-cookie-settings>
          <i class="ph ph-cookie" aria-hidden="true"></i> Çerez tercihleri
        </button>
        <button type="button" class="clear-data" data-clear-app-state>
          <i class="ph ph-trash" aria-hidden="true"></i> Yerel verileri temizle
        </button>
        <p data-settings-status role="status" aria-live="polite"></p>
      </div>
    </section>

    <section class="search-guide" aria-labelledby="search-guide-title">
      <div class="search-guide-copy">
        <p class="app-kicker"><i class="ph ph-sparkle" aria-hidden="true"></i> Masal seçme rehberi</p>
        <h2 id="search-guide-title">Masal oku: yaşa, süreye ve o akşamki ruh hâline göre seç</h2>
        <p>
          MasalNova; resimli uyku masalları, kısa çocuk hikâyeleri, eğitici masallar ve daha uzun maceraları tek bir sakin okuma deneyiminde buluşturur. Üyelik gerekmez; karttaki yaş ve süre bilgisi doğru hikâyeyi hızlıca bulmanıza yardımcı olur.
        </p>
      </div>

      <div class="guide-link-grid">
        <a href="/masallar/kategori/uyku/">
          <i class="ph ph-moon-stars" aria-hidden="true"></i>
          <div><h3>Uyku öncesi masallar</h3><p>Sakin anlatımlı gece hikâyelerini keşfet.</p></div>
          <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
        </a>
        <a href="/masallar/sure/uzun/">
          <i class="ph ph-book-open-text" aria-hidden="true"></i>
          <div><h3>Uzun masallar</h3><p>8-10 dakikalık özgün hikâyeler oku.</p></div>
          <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
        </a>
        <a href="/masallar/resimli/">
          <i class="ph ph-image" aria-hidden="true"></i>
          <div><h3>Resimli masallar</h3><p>Kapak görseliyle birlikte hikâyeni seç.</p></div>
          <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
        </a>
      </div>

      <div class="quick-answers">
        <article>
          <h3>Masallar ücretsiz mi?</h3>
          <p>Evet. MasalNova’daki yazılı masallar ücretsiz ve hesap açmadan çevrimiçi okunabilir.</p>
        </article>
        <article>
          <h3>Kısa mı, uzun mu?</h3>
          <p>Bir iki dakikalık bir mola için kısa masalları; daha gelişmiş bir olay örgüsü için 8-10 dakikalık uzun masalları seçebilirsiniz.</p>
        </article>
        <article>
          <h3>Yaşa uygun masal nasıl bulunur?</h3>
          <p>Kartlardaki 3-5, 5-7 ve 7-9 yaş etiketlerini kullanın veya Masal Bul aracından yaş ve süre seçin.</p>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  import {
    APP_STATE_CHANGE_EVENT,
    APP_STATE_VERSION,
    loadState,
    saveState,
    setPreferences,
    toggleFavorite,
    type AppState,
  } from '../lib/app-state';

  const cards = [...document.querySelectorAll<HTMLElement>('[data-deck-card]')];
  const deck = document.querySelector<HTMLElement>('[data-story-deck]');
  const position = document.querySelector<HTMLElement>('[data-deck-position]');
  let activeIndex = 0;
  let pointerStart = 0;
  let pointerDelta = 0;
  let activePointer: number | null = null;

  function normalizeIndex(index: number) {
    if (!cards.length) return 0;
    return (index + cards.length) % cards.length;
  }

  function renderDeck(nextIndex: number) {
    activeIndex = normalizeIndex(nextIndex);
    const next = normalizeIndex(activeIndex + 1);
    cards.forEach((card, index) => {
      const state = index === activeIndex ? 'active' : index === next ? 'next' : 'hidden';
      card.dataset.state = state;
      card.setAttribute('aria-hidden', state === 'active' ? 'false' : 'true');
      card.toggleAttribute('inert', state !== 'active');
      card.style.removeProperty('--drag-x');
      card.classList.remove('is-dragging');
    });
    if (position) position.textContent = String(activeIndex + 1);
  }

  function showNext() { renderDeck(activeIndex + 1); }
  function showPrevious() { renderDeck(activeIndex - 1); }

  document.querySelector('[data-deck-next]')?.addEventListener('click', showNext);
  document.querySelector('[data-deck-prev]')?.addEventListener('click', showPrevious);

  deck?.addEventListener('keydown', (event) => {
    if (event.key === 'ArrowRight') { event.preventDefault(); showNext(); }
    if (event.key === 'ArrowLeft') { event.preventDefault(); showPrevious(); }
  });

  deck?.addEventListener('pointerdown', (event) => {
    if ((event.target as HTMLElement).closest('a, button, select')) return;
    const activeCard = cards[activeIndex];
    if (!activeCard) return;
    activePointer = event.pointerId;
    pointerStart = event.clientX;
    pointerDelta = 0;
    activeCard.classList.add('is-dragging');
    deck.setPointerCapture(event.pointerId);
  });

  deck?.addEventListener('pointermove', (event) => {
    if (activePointer !== event.pointerId) return;
    pointerDelta = event.clientX - pointerStart;
    cards[activeIndex]?.style.setProperty('--drag-x', `${pointerDelta}px`);
  });

  function finishSwipe(event: PointerEvent) {
    if (activePointer !== event.pointerId) return;
    const delta = pointerDelta;
    activePointer = null;
    if (deck?.hasPointerCapture(event.pointerId)) deck.releasePointerCapture(event.pointerId);
    if (Math.abs(delta) > 64) {
      delta < 0 ? showNext() : showPrevious();
    } else {
      renderDeck(activeIndex);
    }
  }

  deck?.addEventListener('pointerup', finishSwipe);
  deck?.addEventListener('pointercancel', finishSwipe);

  const preferenceInputs = [...document.querySelectorAll<HTMLSelectElement>('[data-story-preference]')];

  function applyPreferencesFromState(state: AppState) {
    preferenceInputs.forEach((input) => {
      const key = input.dataset.storyPreference as 'age' | 'duration' | 'mood';
      if (state.preferences[key]) input.value = state.preferences[key] ?? '';
    });
  }

  function chooseMatchingStory() {
    const values = Object.fromEntries(preferenceInputs.map((input) => [input.dataset.storyPreference, input.value]));
    const matchIndex = cards.findIndex((card) => {
      const ageMatches = !values.age || (card.dataset.age ?? '').split(' ').includes(values.age);
      const durationMatches = !values.duration || card.dataset.duration === values.duration;
      const moodMatches = !values.mood || card.dataset.mood === values.mood;
      return ageMatches && durationMatches && moodMatches;
    });
    renderDeck(matchIndex >= 0 ? matchIndex : 0);
  }

  preferenceInputs.forEach((input) => {
    input.addEventListener('change', () => {
      setPreferences({
        age: preferenceInputs.find((item) => item.dataset.storyPreference === 'age')?.value || null,
        duration: preferenceInputs.find((item) => item.dataset.storyPreference === 'duration')?.value || null,
        mood: preferenceInputs.find((item) => item.dataset.storyPreference === 'mood')?.value || null,
      });
      chooseMatchingStory();
    });
  });

  function renderLocalState(state: AppState) {
    document.querySelectorAll<HTMLButtonElement>('[data-favorite-story]').forEach((button) => {
      const storyId = button.dataset.favoriteStory ?? '';
      const storyTitle = button.dataset.favoriteTitle ?? 'Masal';
      const favorite = state.favorites.includes(storyId);
      button.setAttribute('aria-pressed', String(favorite));
      button.setAttribute('aria-label', favorite
        ? `${storyTitle} masalını favorilerden çıkar`
        : `${storyTitle} masalını favorilere ekle`);
      button.classList.toggle('is-favorite', favorite);
      const icon = button.querySelector('i');
      if (icon) icon.className = favorite ? 'ph-fill ph-heart' : 'ph ph-heart';
    });

    const favoriteCards = [...document.querySelectorAll<HTMLElement>('[data-favorite-card]')];
    let visibleFavorites = 0;
    favoriteCards.forEach((card) => {
      const visible = state.favorites.includes(card.dataset.favoriteCard ?? '');
      card.hidden = !visible;
      if (visible) visibleFavorites += 1;
    });
    const empty = document.querySelector<HTMLElement>('[data-empty-library]');
    if (empty) empty.hidden = visibleFavorites > 0;

    const continueCards = [...document.querySelectorAll<HTMLElement>('[data-continue-story]')];
    const availableStoryIds = new Set(continueCards.map((card) => card.dataset.continueStory ?? ''));
    const availableRecentIds = state.recentStoryIds.filter((id) => availableStoryIds.has(id));
    const hasRecentStories = availableRecentIds.length > 0;
    const featuredIds = continueCards
      .filter((card) => card.dataset.featuredStory === 'true')
      .map((card) => card.dataset.continueStory ?? '');
    const order = hasRecentStories ? availableRecentIds : featuredIds;

    const smartSection = document.querySelector<HTMLElement>('[data-smart-story-section]');
    const smartKickerIcon = document.querySelector<HTMLElement>('[data-smart-story-kicker] i');
    const smartKickerLabel = document.querySelector<HTMLElement>('[data-smart-story-kicker-label]');
    const smartTitle = document.querySelector<HTMLElement>('[data-smart-story-title]');
    const smartIntro = document.querySelector<HTMLElement>('[data-smart-story-intro]');
    const smartLink = document.querySelector<HTMLAnchorElement>('[data-smart-story-link]');
    const smartLinkLabel = document.querySelector<HTMLElement>('[data-smart-story-link-label]');

    if (smartSection) smartSection.dataset.mode = hasRecentStories ? 'recent' : 'best';
    if (smartKickerIcon) smartKickerIcon.className = hasRecentStories ? 'ph ph-bookmark-simple' : 'ph ph-sparkle';
    if (smartKickerLabel) smartKickerLabel.textContent = hasRecentStories ? 'Senin alanın' : 'Klasik masallar';
    if (smartTitle) smartTitle.textContent = hasRecentStories ? 'Kaldığın yerden devam et' : 'En sevilen klasik çocuk masalları';
    if (smartIntro) smartIntro.textContent = hasRecentStories
      ? 'Okumaya başladığın masallara bu cihazdan hızlıca dön.'
      : 'Kırmızı Başlıklı Kız, Pamuk Prenses, Külkedisi, Pinokyo, Uyuyan Güzel ve Keloğlan gibi kuşakların sevdiği Türkçe klasik masalları keşfet.';
    if (smartLink) smartLink.href = hasRecentStories ? '/kitapligim/' : '/masallar/';
    if (smartLinkLabel) smartLinkLabel.textContent = hasRecentStories ? 'Kitaplığı aç' : 'Tüm masallar';

    continueCards.forEach((card) => {
      const id = card.dataset.continueStory ?? '';
      const rank = order.indexOf(id);
      card.style.order = String(rank >= 0 ? rank : 99 + Number(card.dataset.fallbackIndex ?? 0));
      card.hidden = rank < 0;
      const progress = state.progress[id] ?? 0;
      card.querySelector<HTMLElement>('[data-story-progress]')?.style.setProperty('width', `${progress}%`);
      const label = card.querySelector<HTMLElement>('[data-progress-label]');
      if (label) label.textContent = hasRecentStories
        ? (progress > 0 ? `%${progress} tamamlandı` : 'Okumaya devam et')
        : 'Masalı oku';
    });

    const visibleContinue = continueCards.filter((card) => !card.hidden).slice(hasRecentStories ? 3 : 6);
    visibleContinue.forEach((card) => { card.hidden = true; });
  }

  document.querySelectorAll<HTMLButtonElement>('[data-favorite-story]').forEach((button) => {
    button.addEventListener('click', () => {
      const storyId = button.dataset.favoriteStory;
      if (storyId) renderLocalState(toggleFavorite(storyId));
    });
  });

  document.querySelector('[data-clear-app-state]')?.addEventListener('click', () => {
    const cleared = saveState({
      version: APP_STATE_VERSION,
      favorites: [],
      recentStoryIds: [],
      progress: {},
      preferences: { age: null, duration: null, mood: null },
    });
    preferenceInputs.forEach((input) => { input.selectedIndex = input.querySelector('option[selected]') ? [...input.options].findIndex((option) => option.hasAttribute('selected')) : 0; });
    renderLocalState(cleared);
    const status = document.querySelector<HTMLElement>('[data-settings-status]');
    if (status) status.textContent = 'Bu cihazdaki favoriler ve okuma ilerlemesi temizlendi.';
  });

  document.querySelector('[data-open-cookie-settings]')?.addEventListener('click', () => {
    document.querySelector<HTMLButtonElement>('#stcm-icon')?.click();
  });

  window.addEventListener(APP_STATE_CHANGE_EVENT, (event) => {
    const detail = (event as CustomEvent<{ state: AppState }>).detail;
    if (detail?.state) renderLocalState(detail.state);
  });

  const initialState = loadState();
  applyPreferencesFromState(initialState);
  renderLocalState(initialState);
  chooseMatchingStory();
</script>

