---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoCard from '../../components/VideoCard.astro';
import { videos } from '../../data/videos';
import { ageGroups, durationBuckets, storyCategories } from '../../data/taxonomy';

const questions = [
  { group: 'yas', label: 'Çocuğunuzun yaşı?', options: [{ v: '', l: 'Farketmez' }, ...ageGroups.map((a) => ({ v: a.key, l: a.label }))] },
  { group: 'sure', label: 'Ne kadar zamanınız var?', options: [{ v: '', l: 'Farketmez' }, ...durationBuckets.map((d) => ({ v: d.key, l: d.label }))] },
  { group: 'tur', label: 'Nasıl bir masal?', options: [{ v: '', l: 'Farketmez' }, ...storyCategories.map((c) => ({ v: c.key, l: `${c.emoji} ${c.label}` }))] },
];
---
<BaseLayout
  title="Masal Bul | Çocuğunuza Uygun Masalı Bulun — MasalNova"
  description="Çocuğunuzun yaşına, elinizdeki zamana ve ilgisine göre en uygun masalı saniyeler içinde bulun. MasalNova Masal Bul asistanı."
  path="/masal-bul/"
  activeNav="masal-bul"
  noindex={true}
>
  <section class="section">
    <div class="container">
      <header class="page-head">
        <h1>Çocuğunuza Uygun Masalı Bulun 🔮</h1>
        <p>Birkaç soruyu yanıtlayın, size en uygun masalları önerelim. Bu asistan yalnızca yazılı masallar içindir.</p>
      </header>

      <div class="wizard card">
        {questions.map((q) => (
          <div class="q" data-group={q.group}>
            <p class="q-label">{q.label}</p>
            <div class="chips">
              {q.options.map((o, i) => (
                <button type="button" class={`chip${i === 0 ? ' is-active' : ''}`} data-value={o.v}>{o.l}</button>
              ))}
            </div>
          </div>
        ))}
        <button type="button" id="findBtn" class="btn btn-primary find">Masalı Bul ✨</button>
      </div>

      <section id="results" class="results" hidden>
        <h2 id="results-title">Size uygun masallar</h2>
        <div class="grid grid-3" id="story-results" aria-busy="false"></div>
        <p class="result-note" id="story-limit-note" hidden></p>
        <p class="result-status" id="story-status" role="status" hidden></p>
        <p class="empty" id="no-story" hidden>Bu kriterlere tam uyan masal bulunamadı — filtreleri biraz gevşetmeyi deneyin.</p>

        <div id="watch" hidden>
          <h3>İzlemek ister misiniz?</h3>
          <div class="grid grid-3" id="video-results"></div>
        </div>
      </section>
    </div>
  </section>

  <!-- The small video pool remains local; story metadata is fetched on demand. -->
  <div hidden id="video-pool">
    {videos.map((v) => <VideoCard video={v} />)}
  </div>
</BaseLayout>

<style>
  .page-head { color: #fff; margin-bottom: 20px; }
  .page-head h1 { font-size: clamp(1.8rem, 4.5vw, 2.6rem); }
  .page-head p { color: var(--soft); max-width: 66ch; margin-top: 8px; }

  .wizard { background: #fff; padding: 24px; display: flex; flex-direction: column; gap: 20px; }
  .q-label { font-family: var(--font-display); font-weight: 800; color: var(--ink); margin-bottom: 10px; font-size: 1.1rem; }
  .chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip { border: 1px solid var(--line); background: var(--paper-2); color: var(--ink); font-family: var(--font-display); font-weight: 700; padding: 9px 16px; border-radius: 999px; transition: background .15s ease, color .15s ease, border-color .15s ease; }
  .chip:hover { border-color: var(--blue); }
  .chip.is-active { background: var(--blue); color: #fff; border-color: var(--blue); }
  .find { align-self: flex-start; margin-top: 4px; }

  .results { margin-top: 34px; }
  .results h2 { color: #fff; font-size: 1.5rem; margin-bottom: 16px; }
  #watch { margin-top: 34px; }
  #watch h3 { color: #fff; font-size: 1.25rem; margin-bottom: 14px; }
  .result-status, .result-note { color: var(--soft); margin-top: 14px; }
  .empty { color: #fff; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2); border-radius: var(--radius); padding: 22px; text-align: center; }
</style>

<style is:global>
  .story-result-card {
    --card-accent: #2f74e8;
    display: flex;
    min-width: 0;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 30px;
    background: radial-gradient(120% 100% at 0 0, color-mix(in srgb, var(--card-accent) 50%, transparent), transparent 58%), linear-gradient(155deg, color-mix(in srgb, var(--card-accent) 34%, #132d62), #08152f 78%);
    color: #fff;
    box-shadow: 0 24px 64px rgba(5,18,52,.28);
    transition: transform .28s cubic-bezier(.2,.75,.25,1), box-shadow .28s ease, border-color .28s ease;
  }
  .story-result-card:hover { transform: translateY(-8px); border-color: rgba(255,255,255,.42); box-shadow: 0 34px 82px rgba(3,14,44,.4); }
  .story-result-media { position: relative; display: grid; overflow: hidden; aspect-ratio: 4 / 3; place-items: center; background: radial-gradient(120% 120% at 18% 8%, rgba(255,255,255,.4), transparent 55%), var(--card-accent); }
  .story-result-media::after { position: absolute; inset: auto 0 0; height: 30%; background: linear-gradient(180deg, transparent, rgba(5,18,44,.34)); content: ""; pointer-events: none; }
  .story-result-media img { width: 100%; height: 100%; object-fit: cover; transition: transform .55s cubic-bezier(.2,.75,.25,1), filter .35s ease; }
  .story-result-card:hover .story-result-media img { transform: scale(1.045); filter: saturate(1.06); }
  .story-result-placeholder { font-size: 3rem; filter: drop-shadow(0 6px 10px rgba(0,0,0,.25)); }
  .story-result-badge, .story-result-audio { position: absolute; z-index: 2; top: 14px; padding: 7px 11px; border: 1px solid rgba(255,255,255,.2); border-radius: 9px; background: rgba(5,16,38,.78); color: rgba(255,255,255,.94); box-shadow: 0 8px 22px rgba(0,0,0,.2); backdrop-filter: blur(12px); font-size: .75rem; font-weight: 800; line-height: 1; }
  .story-result-badge { right: 14px; }
  .story-result-audio { left: 14px; }
  .story-result-body { display: flex; min-height: 245px; flex: 1; flex-direction: column; gap: 10px; padding: 22px 22px 24px; }
  .story-result-eyebrow { color: rgba(255,255,255,.68); font-size: .72rem; font-weight: 850; letter-spacing: .1em; text-transform: uppercase; }
  .story-result-title { color: #fff; font-family: var(--font-display); font-size: clamp(1.18rem,2vw,1.38rem); font-weight: 800; line-height: 1.2; letter-spacing: -.025em; }
  .story-result-meta { display: flex; flex-wrap: wrap; color: rgba(255,255,255,.78); font-size: .78rem; font-weight: 750; }
  .story-result-meta > span { display: inline-flex; align-items: center; }
  .story-result-meta > span + span::before { margin: 0 8px; color: rgba(255,255,255,.42); content: "·"; }
  .story-result-description { display: -webkit-box; overflow: hidden; color: rgba(255,255,255,.88); font-size: .91rem; font-weight: 560; line-height: 1.62; -webkit-box-orient: vertical; -webkit-line-clamp: 4; }
  .story-result-link { align-self: flex-start; margin-top: auto; padding: 8px 13px; border: 1px solid rgba(255,255,255,.22); border-radius: 999px; background: rgba(255,255,255,.12); color: #fff; font-size: .8rem; font-weight: 850; transition: background .2s ease, color .2s ease; }
  .story-result-card:hover .story-result-link { background: #fff; color: #102a66; }
  @media (max-width: 640px) {
    .story-result-card { border-radius: 24px; }
    .story-result-body { min-height: 225px; padding: 18px 18px 20px; }
    .story-result-description { -webkit-line-clamp: 3; }
  }
</style>

<script>
  import {
    createStoryResultCard,
    loadStoryIndex,
    type StoryMetadata,
  } from '../../lib/story-metadata';

  const STORY_RESULT_LIMIT = 12;
  const sel: Record<string, string> = { yas: '', sure: '', tur: '' };
  document.querySelectorAll<HTMLElement>('.q').forEach((q) => {
    const group = q.dataset.group!;
    q.querySelectorAll<HTMLButtonElement>('.chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        q.querySelectorAll('.chip').forEach((c) => c.classList.toggle('is-active', c === chip));
        sel[group] = chip.dataset.value || '';
      });
    });
  });

  const turToVideoCat: Record<string, string> = { uyku: 'sarkilar', kisa: 'sarkilar', egitici: 'egitici', hayvan: 'hayvan' };

  const findButton = document.getElementById('findBtn') as HTMLButtonElement;
  findButton.addEventListener('click', async () => {
    const results = document.getElementById('results') as HTMLElement;
    const out = document.getElementById('story-results') as HTMLElement;
    const status = document.getElementById('story-status') as HTMLElement;
    const limitNote = document.getElementById('story-limit-note') as HTMLElement;
    const noStory = document.getElementById('no-story') as HTMLElement;

    results.hidden = false;
    out.setAttribute('aria-busy', 'true');
    out.replaceChildren();
    noStory.hidden = true;
    limitNote.hidden = true;
    status.hidden = false;
    status.textContent = 'Size uygun masallar aranıyor…';
    findButton.disabled = true;

    let stories: StoryMetadata[];
    try {
      stories = await loadStoryIndex();
    } catch {
      status.textContent = 'Masallar şu anda yüklenemedi. Lütfen yeniden deneyin.';
      out.setAttribute('aria-busy', 'false');
      findButton.disabled = false;
      return;
    }

    const matches = stories.filter((story) => {
      const okTur = !sel.tur || story.categories.includes(sel.tur);
      const okYas = !sel.yas || story.ageGroups.includes(sel.yas);
      const okSure = !sel.sure || story.duration === sel.sure;
      return okTur && okYas && okSure;
    });

    const visibleMatches = matches.slice(0, STORY_RESULT_LIMIT);
    out.replaceChildren(...visibleMatches.map(createStoryResultCard));
    out.setAttribute('aria-busy', 'false');
    status.hidden = true;
    noStory.hidden = matches.length !== 0;
    limitNote.hidden = matches.length <= STORY_RESULT_LIMIT;
    limitNote.textContent = matches.length > STORY_RESULT_LIMIT
      ? `${matches.length} uygun masaldan ilk ${STORY_RESULT_LIMIT} öneri gösteriliyor. Seçimleri daraltarak daha özel sonuçlar bulabilirsiniz.`
      : '';
    document.getElementById('results-title')!.textContent =
      matches.length ? `Size uygun ${matches.length} masal` : 'Sonuç';

    // İzlemek ister misiniz? — max 2 matching videos
    const vcat = turToVideoCat[sel.tur] || '';
    const vPool = Array.from(document.querySelectorAll<HTMLElement>('#video-pool .video-card'));
    const vMatches = (vcat ? vPool.filter((c) => c.dataset.cats!.split(' ').includes(vcat)) : vPool).slice(0, 2);
    const vout = document.getElementById('video-results')!;
    vout.innerHTML = '';
    vMatches.forEach((m) => vout.appendChild(m.cloneNode(true)));
    (document.getElementById('watch') as HTMLElement).hidden = vMatches.length === 0;

    findButton.disabled = false;
    results.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
