---
import '../styles/global.css';
import '../styles/reader.css';
import BaseHead from '../components/BaseHead.astro';
import Consent from '../components/Consent.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article' | 'video.other';
  imageAlt?: string;
  publishedTime?: string;
  modifiedTime?: string;
  preloadImage?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  activeNav?: string;
  readerPage?: boolean;
  appShell?: boolean;
}
const {
  title,
  description,
  path,
  image,
  noindex,
  ogType,
  imageAlt,
  publishedTime,
  modifiedTime,
  preloadImage,
  jsonLd,
  activeNav,
  readerPage = false,
  appShell,
} = Astro.props;
const useAppShell = appShell ?? !readerPage;
---
<!doctype html>
<html lang="tr" class:list={[{ 'is-reader-page': readerPage, 'is-app-shell': useAppShell }]}>
  <head>
    {
      readerPage && (
        <script is:inline>
          {`
            (function () {
              var d = document.documentElement.dataset;
              var p = {};
              try {
                p = JSON.parse(localStorage.getItem('masalnova:reader') || '{}') || {};
              } catch (e) {}
              var valid = {
                theme: ['system', 'light', 'sepia', 'dark'],
                size: ['s', 'm', 'l', 'xl'],
                font: ['sans', 'serif'],
                leading: ['compact', 'comfortable', 'spacious']
              };
              var defaults = { theme: 'system', size: 'm', font: 'sans', leading: 'comfortable' };
              for (var k in defaults) {
                var v = valid[k].indexOf(p[k]) !== -1 ? p[k] : defaults[k];
                d['reader' + k.charAt(0).toUpperCase() + k.slice(1)] = v;
              }
              try {
                d.bedtimeMode = localStorage.getItem('masalnova:bedtime-mode') === 'true' ? 'true' : 'false';
              } catch (e) {
                d.bedtimeMode = 'false';
              }
            })();
          `}
        </script>
      )
    }
    <BaseHead
      title={title}
      description={description}
      path={path}
      image={image}
      noindex={noindex}
      ogType={ogType}
      imageAlt={imageAlt}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      preloadImage={preloadImage}
      jsonLd={jsonLd}
    />
    <Consent />
  </head>
  <body class:list={[{ 'app-shell': useAppShell }]}>
    <a class="skip-link" href="#main">İçeriğe geç</a>
    {!readerPage && <Header active={activeNav} />}
    <main id="main">
      <slot />
    </main>
    {!readerPage && <Footer />}
    <script is:inline>
      {`
        if ('serviceWorker' in navigator && location.protocol === 'https:') {
          window.addEventListener('load', function () {
            navigator.serviceWorker.register('/sw.js').catch(function () {});
          });
        }
      `}
    </script>
  </body>
</html>
