---
interface Props {
  emoji?: string;
  color?: string;
  image?: string;
  alt?: string;
  ratio?: string;
  big?: boolean;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
}
const {
  emoji = '📖',
  color = '#2f74e8',
  image,
  alt = '',
  ratio = '16 / 10',
  big = false,
  loading = 'lazy',
  fetchpriority = 'auto',
  sizes = '(max-width: 640px) 100vw, (max-width: 900px) 50vw, 33vw',
} = Astro.props;
const [ratioWidth, ratioHeight] = ratio.split('/').map((part) => Number(part.trim()));
const intrinsicWidth = 1200;
const intrinsicHeight = Number.isFinite(ratioWidth) && Number.isFinite(ratioHeight) && ratioWidth > 0
  ? Math.round(intrinsicWidth * ratioHeight / ratioWidth)
  : 750;
---
{image ? (
  <img
    class="cover"
    src={image}
    alt={alt}
    width={intrinsicWidth}
    height={intrinsicHeight}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    sizes={sizes}
    style={`aspect-ratio:${ratio}`}
  />
) : (
  <div
    class="cover cover-ph"
    style={`aspect-ratio:${ratio}; background: radial-gradient(120% 120% at 18% 8%, rgba(255,255,255,.4), transparent 55%), ${color};`}
    aria-hidden="true"
  >
    <span class={big ? 'emoji big' : 'emoji'}>{emoji}</span>
  </div>
)}
<style>
  .cover { width: 100%; object-fit: cover; display: block; }
  .cover-ph { display: grid; place-items: center; }
  .emoji { font-size: 3rem; filter: drop-shadow(0 6px 10px rgba(0, 0, 0, 0.25)); }
  .emoji.big { font-size: 4.6rem; }
</style>
