---
// Lite YouTube: shows only a thumbnail until the user clicks.
// The real iframe (and any playback) loads ONLY after a deliberate click — never autoplay on load.
interface Props { videoId: string; title: string }
const { videoId, title } = Astro.props;
const poster = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
const posterFallback = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
---
<div class="yt-lite" data-ytid={videoId}>
  <button class="yt-poster" type="button" aria-label={`${title} videosunu oynat`}>
    <img src={poster} alt="" loading="lazy" data-fallback={posterFallback} />
    <span class="yt-play" aria-hidden="true">
      <svg viewBox="0 0 68 48" width="68" height="48"><path class="bg" d="M66.5 7.7c-.8-2.9-3-5.1-5.9-5.9C55.3.5 34 .5 34 .5S12.7.5 7.4 1.8C4.5 2.6 2.3 4.8 1.5 7.7.2 13 .2 24 .2 24s0 11 1.3 16.3c.8 2.9 3 5.1 5.9 5.9C12.7 47.5 34 47.5 34 47.5s21.3 0 26.6-1.3c2.9-.8 5.1-3 5.9-5.9C67.8 35 67.8 24 67.8 24s0-11-1.3-16.3z" fill="#f00"/><path d="M27 34l18-10-18-10z" fill="#fff"/></svg>
    </span>
  </button>
</div>
<style>
  .yt-lite { position: relative; aspect-ratio: 16 / 9; width: 100%; border-radius: var(--radius); overflow: hidden; background: #0a225e; box-shadow: var(--shadow-lg); }
  .yt-poster { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; padding: 0; background: none; cursor: pointer; }
  .yt-poster img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .yt-play { position: absolute; inset: 0; margin: auto; width: 68px; height: 48px; filter: drop-shadow(0 4px 10px rgba(0,0,0,.4)); transition: transform .15s ease; }
  .yt-play .bg { transition: fill .15s ease; }
  .yt-poster:hover .yt-play { transform: scale(1.08); }
  .yt-lite :global(iframe) { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
</style>
<script>
  // Fallback poster if maxres is missing
  document.querySelectorAll('.yt-lite img[data-fallback]').forEach((img) => {
    const el = img as HTMLImageElement;
    el.addEventListener('error', () => { el.src = el.dataset.fallback || ''; }, { once: true });
  });
  // Click-to-play: build the iframe only on a deliberate user click.
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.yt-lite .yt-poster');
    if (!btn) return;
    const lite = btn.closest('.yt-lite') as HTMLElement;
    const id = lite.dataset.ytid;
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`;
    iframe.title = 'YouTube video';
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
    iframe.allowFullscreen = true;
    lite.replaceChildren(iframe);
  });
</script>
