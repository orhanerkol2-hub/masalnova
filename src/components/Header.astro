---
interface Props { active?: string }

const { active = '' } = Astro.props;
const activeKey = active === 'home'
  ? 'today'
  : ['masallar', 'videolar', 'masal-bul'].includes(active)
    ? 'discover'
    : active;

const links = [
  { href: '/', label: 'Bugün', key: 'today', icon: 'house' },
  { href: '/masallar/', label: 'Keşfet', key: 'discover', icon: 'compass' },
  { href: '/#kitapligim', label: 'Kitaplığım', key: 'library', icon: 'book-bookmark' },
  { href: '/#ayarlar', label: 'Ayarlar', key: 'settings', icon: 'gear' },
];
---

<header class="app-header" data-app-header>
  <aside class="app-rail" aria-label="Uygulama menüsü">
    <a class="rail-brand" href="/" aria-label="MasalNova ana sayfa">
      <img class="rail-logo rail-logo--full" src="/logo.webp" alt="MasalNova" width="188" height="48" />
      <img class="rail-logo rail-logo--compact" src="/app-icon-192.png" alt="" width="48" height="48" />
    </a>

    <nav class="rail-nav" aria-label="Ana menü">
      {links.map((item) => (
        <a
          href={item.href}
          class:list={['rail-link', { 'is-active': activeKey === item.key }]}
          aria-current={activeKey === item.key ? 'page' : undefined}
        >
          <i class={`ph ph-${item.icon}`} aria-hidden="true"></i>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="rail-note">
      <i class="ph ph-moon-stars" aria-hidden="true"></i>
      <p>Her akşam sakin bir masal.</p>
    </div>

    <div class="rail-legal">
      <a href="/impressum/">Legal Notice</a>
      <a href="/datenschutz/">Privacy</a>
    </div>
  </aside>

  <div class="app-topbar">
    <a class="mobile-brand" href="/" aria-label="MasalNova ana sayfa">
      <img src="/logo.webp" alt="MasalNova" width="154" height="39" />
    </a>
    <div class="topbar-actions">
      <a class="top-action" href="/ara/" aria-label="Ara">
        <i class="ph ph-magnifying-glass" aria-hidden="true"></i>
      </a>
      <button class="install-action" type="button" data-install-app>
        <i class="ph ph-download-simple" aria-hidden="true"></i>
        <span>Uygulamayı yükle</span>
      </button>
      <a class="top-action settings-action" href="/#ayarlar" aria-label="Ayarlar">
        <i class="ph ph-gear" aria-hidden="true"></i>
      </a>
    </div>
  </div>

  <nav class="mobile-nav" aria-label="Mobil ana menü">
    {links.map((item) => (
      <a
        href={item.href}
        class:list={['mobile-link', { 'is-active': activeKey === item.key }]}
        aria-current={activeKey === item.key ? 'page' : undefined}
      >
        <i class={`ph ph-${item.icon}`} aria-hidden="true"></i>
        <span>{item.label}</span>
      </a>
    ))}
  </nav>

  <div class="install-toast" data-install-toast role="status" aria-live="polite" hidden></div>
</header>

<script>
  let installPrompt: any = null;
  const installButtons = [...document.querySelectorAll<HTMLElement>('[data-install-app]')];
  const toast = document.querySelector<HTMLElement>('[data-install-toast]');
  let toastTimer: number | undefined;

  function showInstallMessage(message: string) {
    if (!toast) return;
    window.clearTimeout(toastTimer);
    toast.textContent = message;
    toast.hidden = false;
    requestAnimationFrame(() => toast.classList.add('is-visible'));
    toastTimer = window.setTimeout(() => {
      toast.classList.remove('is-visible');
      window.setTimeout(() => { toast.hidden = true; }, 180);
    }, 4200);
  }

  window.addEventListener('beforeinstallprompt', (event) => {
    event.preventDefault();
    installPrompt = event;
    installButtons.forEach((button) => button.classList.add('is-ready'));
  });

  window.addEventListener('appinstalled', () => {
    installPrompt = null;
    installButtons.forEach((button) => {
      button.classList.remove('is-ready');
      button.classList.add('is-installed');
      const label = button.querySelector('span');
      if (label) label.textContent = 'Yüklendi';
    });
    showInstallMessage('MasalNova cihazına eklendi.');
  });

  installButtons.forEach((button) => {
    button.addEventListener('click', async () => {
      const standalone = window.matchMedia('(display-mode: standalone)').matches
        || (navigator as Navigator & { standalone?: boolean }).standalone;
      if (standalone) {
        showInstallMessage('MasalNova zaten uygulama olarak açık.');
        return;
      }

      if (installPrompt) {
        await installPrompt.prompt();
        installPrompt = null;
        return;
      }

      const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
      showInstallMessage(isIOS
        ? 'Safari’de Paylaş menüsünü açıp “Ana Ekrana Ekle”yi seç.'
        : 'Tarayıcı menüsünden “Uygulamayı yükle” veya “Ana ekrana ekle”yi seç.');
    });
  });
</script>

<style>
  .app-rail {
    position: fixed;
    z-index: 130;
    inset: 0 auto 0 0;
    width: var(--app-rail);
    display: flex;
    flex-direction: column;
    padding: 30px 18px 22px;
    border-right: 1px solid rgba(255,255,255,.13);
    background: linear-gradient(180deg, rgba(4,41,143,.98), rgba(4,29,105,.97));
    box-shadow: 24px 0 70px rgba(0,20,91,.18);
  }

  .rail-brand {
    display: flex;
    align-items: center;
    min-height: 52px;
    padding: 0 6px;
  }

  .rail-logo--full { width: 176px; height: auto; }
  .rail-logo--compact { display: none; }

  .rail-nav {
    display: grid;
    gap: 9px;
    margin-top: 58px;
  }

  .rail-link {
    display: flex;
    align-items: center;
    gap: 15px;
    min-height: 52px;
    padding: 0 16px;
    border: 1px solid transparent;
    border-radius: 17px;
    color: rgba(255,255,255,.72);
    font-size: .96rem;
    font-weight: 800;
    transition: color .18s ease, background .18s ease, transform .18s ease;
  }

  .rail-link i { font-size: 1.42rem; }
  .rail-link:hover { color: #fff; background: rgba(255,255,255,.09); transform: translateX(2px); }
  .rail-link.is-active {
    color: #fff;
    border-color: rgba(255,255,255,.15);
    background: rgba(255,255,255,.14);
    box-shadow: inset 3px 0 0 var(--app-yellow), 0 12px 24px rgba(2,19,78,.22);
  }

  .rail-note {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-top: auto;
    padding: 16px 14px;
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 17px;
    background: rgba(255,255,255,.07);
    color: rgba(255,255,255,.82);
    font-size: .82rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .rail-note i { margin-top: 1px; color: var(--app-yellow); font-size: 1.2rem; }

  .rail-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 7px 12px;
    margin: 15px 5px 0;
    color: rgba(255,255,255,.46);
    font-size: .67rem;
    font-weight: 700;
  }

  .rail-legal a:hover { color: #fff; }

  .app-topbar {
    position: fixed;
    z-index: 120;
    top: 0;
    right: 0;
    left: var(--app-rail);
    height: var(--app-nav-height);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 12px clamp(22px, 4vw, 54px);
    border-bottom: 1px solid rgba(255,255,255,.08);
    background: linear-gradient(180deg, rgba(6,48,165,.95), rgba(6,48,165,.72));
    backdrop-filter: blur(18px);
  }

  .mobile-brand { display: none; }
  .topbar-actions { display: flex; align-items: center; gap: 10px; }

  .top-action,
  .install-action {
    min-height: 44px;
    border: 1px solid rgba(255,255,255,.17);
    background: rgba(255,255,255,.1);
    color: #fff;
    box-shadow: 0 10px 24px rgba(0,23,101,.12);
    transition: transform .18s ease, background .18s ease, border-color .18s ease;
  }

  .top-action {
    width: 44px;
    display: grid;
    place-items: center;
    border-radius: 14px;
    font-size: 1.22rem;
  }

  .install-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 0 18px;
    border-radius: 15px;
    font-size: .86rem;
    font-weight: 900;
  }

  .install-action.is-ready {
    border-color: rgba(255,215,84,.6);
    background: var(--app-yellow);
    color: #193068;
  }

  .top-action:hover,
  .install-action:hover { transform: translateY(-2px); background: rgba(255,255,255,.18); }
  .install-action.is-ready:hover { background: #ffd65b; }
  .mobile-nav { display: none; }

  .install-toast {
    position: fixed;
    z-index: 190;
    right: 28px;
    bottom: 28px;
    max-width: min(360px, calc(100vw - 36px));
    padding: 14px 17px;
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 15px;
    background: #fff;
    color: #102b6d;
    box-shadow: 0 20px 60px rgba(0,20,80,.35);
    font-size: .9rem;
    font-weight: 800;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity .18s ease, transform .18s ease;
  }

  .install-toast.is-visible { opacity: 1; transform: none; }

  @media (max-width: 1099px) and (min-width: 721px) {
    .app-rail { width: var(--app-rail-compact); align-items: center; padding: 24px 12px 20px; }
    .rail-logo--full { display: none; }
    .rail-logo--compact { display: block; width: 50px; height: 50px; border-radius: 15px; }
    .rail-nav { width: 100%; margin-top: 45px; }
    .rail-link { justify-content: center; min-height: 58px; padding: 0; border-radius: 17px; }
    .rail-link i { font-size: 1.55rem; }
    .rail-link span, .rail-note p, .rail-legal { display: none; }
    .rail-note { justify-content: center; padding: 14px; }
    .app-topbar { left: var(--app-rail-compact); }
  }

  @media (max-width: 720px) {
    .app-rail { display: none; }
    .app-topbar {
      left: 0;
      height: 70px;
      justify-content: space-between;
      padding: 10px 15px 9px;
      background: rgba(6,45,151,.94);
    }
    .mobile-brand { display: block; width: 136px; }
    .mobile-brand img { width: 100%; height: auto; }
    .settings-action { display: none; }
    .install-action { width: 43px; min-height: 43px; padding: 0; }
    .install-action span { display: none; }
    .top-action { width: 43px; min-height: 43px; }
    .mobile-nav {
      position: fixed;
      z-index: 150;
      right: 0;
      bottom: 0;
      left: 0;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      min-height: calc(70px + env(safe-area-inset-bottom));
      padding: 7px 6px calc(7px + env(safe-area-inset-bottom));
      border-top: 1px solid rgba(15,44,111,.12);
      background: rgba(255,255,255,.96);
      box-shadow: 0 -12px 40px rgba(0,25,93,.18);
      backdrop-filter: blur(18px);
    }
    .mobile-link {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      min-width: 0;
      border-radius: 13px;
      color: #6b789c;
      font-size: .62rem;
      font-weight: 900;
      line-height: 1.1;
    }
    .mobile-link i { font-size: 1.34rem; }
    .mobile-link.is-active { background: #edf3ff; color: #0a43c1; }
    .install-toast { right: 18px; bottom: calc(88px + env(safe-area-inset-bottom)); }
  }
</style>
