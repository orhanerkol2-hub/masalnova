---
import ReadingSettings from './ReadingSettings.astro';

interface Props {
  backHref: string;
  audioSrc?: string | undefined;
  storyId: string;
}

const { backHref, audioSrc, storyId } = Astro.props;
---

<div class="reading-toolbar" data-reading-toolbar data-story-id={storyId}>
  <div class="reading-toolbar__inner">
    <a class="reading-toolbar__back" href={backHref}>
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="reading-toolbar__back-label">Masallara dön</span>
    </a>

    <div class="reading-toolbar__actions">
      <button
        class="reading-toolbar__btn reading-toolbar__bedtime"
        type="button"
        data-bedtime-toggle
        aria-pressed="false"
        aria-label="Uyku modunu aç"
        title="Uyku modu"
      >
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M20.2 15.2A8.5 8.5 0 0 1 8.8 3.8 8.5 8.5 0 1 0 20.2 15.2Z" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      {
        audioSrc && (
          <button class="reading-toolbar__btn" type="button" data-audio-toggle aria-label="Sesli masalı oynat" aria-pressed="false">
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
              <path d="M4 6.5v5h2.8L11 15V3L6.8 6.5H4Z" />
              <path d="M13 6.2a3.5 3.5 0 0 1 0 5.6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
            </svg>
          </button>
        )
      }
      <button
        class="reading-toolbar__btn reading-toolbar__aa"
        type="button"
        data-settings-open
        aria-haspopup="dialog"
        aria-label="Okuma ayarlarını aç"
      >
        <span aria-hidden="true">Aa</span>
      </button>
    </div>
  </div>

  <div
    class="reading-toolbar__progress"
    data-reading-progress
    role="progressbar"
    aria-label="Okuma ilerlemesi"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="0"
  >
    <div class="reading-toolbar__progress-bar" data-reading-progress-bar />
  </div>
</div>

<ReadingSettings />

{audioSrc && <audio data-story-audio src={audioSrc} preload="none"></audio>}

<style>
  .reading-toolbar {
    position: sticky;
    top: 0;
    z-index: 30;
    background: color-mix(in srgb, var(--reader-surface) 94%, transparent);
    border-bottom: 1px solid var(--reader-border);
    color: var(--reader-text-color);
    backdrop-filter: blur(14px);
  }

  .reading-toolbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    height: var(--reader-toolbar-height);
    max-width: var(--reader-content-width);
    margin: 0 auto;
    padding: 0 clamp(18px, 5vw, 24px);
  }

  .reading-toolbar__back {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    min-height: 44px;
    padding: 0 0.25rem;
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--reader-text-soft);
  }

  .reading-toolbar__back:hover {
    color: var(--reader-text-color);
  }

  .reading-toolbar__actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .reading-toolbar__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    border: 0;
    border-radius: 12px;
    background: transparent;
    color: var(--reader-text-soft);
  }

  .reading-toolbar__btn:hover {
    background: var(--reader-surface-raised);
    color: var(--reader-text-color);
  }

  .reading-toolbar__aa {
    border: 1px solid var(--reader-border);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.06rem;
    font-weight: 800;
  }

  .reading-toolbar__bedtime[aria-pressed='true'] {
    background: var(--reader-surface-raised);
    color: var(--reader-accent);
  }

  .reading-toolbar__progress {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 3px;
    overflow: hidden;
  }

  .reading-toolbar__progress-bar {
    height: 100%;
    background: var(--reader-progress);
    transform: scaleX(0);
    transform-origin: left;
    will-change: transform;
  }

  @media (max-width: 360px) {
    .reading-toolbar__back-label {
      display: none;
    }
  }
</style>

<script>
  import { recordRecent, setProgress } from '../lib/app-state';

  const toolbar = document.querySelector<HTMLElement>('[data-reading-toolbar]');
  const storyId = toolbar?.dataset.storyId;
  const progress = document.querySelector<HTMLElement>('[data-reading-progress]');
  const bar = document.querySelector<HTMLElement>('[data-reading-progress-bar]');
  const article = document.querySelector<HTMLElement>('[data-reader-article]');

  if (storyId) recordRecent(storyId);

  if (progress && bar && article) {
    const SAVE_INTERVAL_MS = 800;
    let ticking = false;
    let lastAnnounced = -1;
    let persistAfterFrame = false;
    let latestProgress: number | null = null;
    let lastSavedProgress = -1;
    let lastSavedAt = 0;
    let saveTimer: ReturnType<typeof setTimeout> | undefined;

    const flushProgress = () => {
      if (saveTimer !== undefined) {
        window.clearTimeout(saveTimer);
        saveTimer = undefined;
      }
      if (!storyId || latestProgress === null || latestProgress === lastSavedProgress) return;

      setProgress(storyId, latestProgress);
      lastSavedProgress = latestProgress;
      lastSavedAt = performance.now();
    };

    const scheduleProgressSave = (pct: number) => {
      latestProgress = pct;
      const remaining = SAVE_INTERVAL_MS - (performance.now() - lastSavedAt);
      if (remaining <= 0) {
        flushProgress();
      } else if (saveTimer === undefined) {
        saveTimer = window.setTimeout(flushProgress, remaining);
      }
    };

    const update = () => {
      ticking = false;
      const start = article.offsetTop;
      const end = start + article.offsetHeight - window.innerHeight;
      const range = Math.max(1, end - start);
      const ratio = Math.min(1, Math.max(0, (window.scrollY - start) / range));
      bar.style.transform = `scaleX(${ratio})`;
      const pct = Math.round(ratio * 100);
      const step = Math.round(pct / 10) * 10;
      if (step !== lastAnnounced) {
        lastAnnounced = step;
        progress.setAttribute('aria-valuenow', String(step));
      }
      if (persistAfterFrame) {
        persistAfterFrame = false;
        scheduleProgressSave(pct);
      }
    };

    const onScroll = () => {
      persistAfterFrame = true;
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    const onResize = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });
    window.addEventListener('pagehide', flushProgress);
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') flushProgress();
    });
    update();
  }

  const audioBtn = document.querySelector<HTMLButtonElement>('[data-audio-toggle]');
  const audio = document.querySelector<HTMLAudioElement>('[data-story-audio]');

  if (audioBtn && audio) {
    const syncAudioButton = () => {
      audioBtn.setAttribute('aria-pressed', String(!audio.paused));
      audioBtn.setAttribute('aria-label', audio.paused ? 'Sesli masalı oynat' : 'Sesli masalı duraklat');
    };

    audioBtn.addEventListener('click', () => {
      if (audio.paused) void audio.play();
      else audio.pause();
    });
    audio.addEventListener('play', syncAudioButton);
    audio.addEventListener('pause', syncAudioButton);
  }

  const bedtimeBtn = document.querySelector<HTMLButtonElement>('[data-bedtime-toggle]');

  if (bedtimeBtn) {
    const storageKey = 'masalnova:bedtime-mode';
    const root = document.documentElement;

    const setBedtimeMode = (active: boolean, persist = true) => {
      root.dataset.bedtimeMode = String(active);
      bedtimeBtn.setAttribute('aria-pressed', String(active));
      bedtimeBtn.setAttribute('aria-label', active ? 'Uyku modunu kapat' : 'Uyku modunu aç');
      bedtimeBtn.title = active ? 'Uyku modunu kapat' : 'Uyku modu';

      if (persist) {
        try { localStorage.setItem(storageKey, String(active)); } catch {}
      }
    };

    setBedtimeMode(root.dataset.bedtimeMode === 'true', false);
    bedtimeBtn.addEventListener('click', () => {
      setBedtimeMode(root.dataset.bedtimeMode !== 'true');
    });
  }
</script>
