---
interface Props {
  title: string;
  description: string;
  /** path only, e.g. "/masallar/" — combined with site for canonical/OG */
  path?: string;
  image?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article' | 'video.other';
  imageAlt?: string;
  publishedTime?: string;
  modifiedTime?: string;
  preloadImage?: string;
  /** extra JSON-LD object(s) for this page */
  jsonLd?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description,
  path = '/',
  image = '/logo.png',
  noindex = false,
  ogType = 'website',
  imageAlt = title,
  publishedTime,
  modifiedTime,
  preloadImage,
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL('https://masalnova.com');
const canonical = new URL(path, site).href;
const imageUrl = new URL(image, site).href;

const orgGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://masalnova.com/#organization',
      name: 'MasalNova Çocuk',
      alternateName: 'MasalNova',
      description: 'Çocuklar için ücretsiz Türkçe masallar, uyku hikâyeleri ve güvenli videolar.',
      url: 'https://masalnova.com/',
      logo: {
        '@type': 'ImageObject',
        '@id': 'https://masalnova.com/#logo',
        url: 'https://masalnova.com/app-icon-512.png',
        contentUrl: 'https://masalnova.com/app-icon-512.png',
        width: 512,
        height: 512,
        caption: 'MasalNova',
      },
      sameAs: ['https://www.youtube.com/@masalnovacocuk'],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://masalnova.com/#website',
      url: 'https://masalnova.com/',
      name: 'MasalNova Çocuk',
      alternateName: 'MasalNova',
      description: 'Masal oku: ücretsiz Türkçe uyku masalları, kısa ve eğitici çocuk hikâyeleri.',
      inLanguage: 'tr-TR',
      publisher: { '@id': 'https://masalnova.com/#organization' },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://masalnova.com/ara/?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};

const extra = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content="#0737ad" />
<meta name="application-name" content="MasalNova" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="MasalNova" />
<meta name="author" content="MasalNova Çocuk" />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
{preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

<!-- Google AdSense -->
<meta name="google-adsense-account" content="ca-pub-5606540854153205" />
<script async is:inline src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5606540854153205" crossorigin="anonymous"></script>

<title>{title}</title>
<meta name="description" content={description} />
<meta
  name="robots"
  content={noindex
    ? 'noindex, follow'
    : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
/>
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="tr" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />

<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="MasalNova Çocuk" />
<meta property="og:locale" content="tr_TR" />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={imageAlt} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />

<link rel="icon" type="image/png" sizes="192x192" href="/app-icon-192.png" />

<script type="application/ld+json" set:html={JSON.stringify(orgGraph)} />
{extra.map((obj) => (
  <script type="application/ld+json" set:html={JSON.stringify(obj)} />
))}
