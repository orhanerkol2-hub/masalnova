---
interface Props {
  href: string;
  emoji: string;
  label: string;
  desc?: string;
  count?: number;
  color?: string;
}
const { href, emoji, label, desc, count, color = '#2f74e8' } = Astro.props;
---
<a class="cat-card" href={href} style={`--c:${color}`}>
  <span class="ce" aria-hidden="true">{emoji}</span>
  <span class="cl">{label}</span>
  {desc && <span class="cd">{desc}</span>}
  {typeof count === 'number' && <span class="cc">{count} masal</span>}
</a>
<style>
  .cat-card {
    display: flex; flex-direction: column; align-items: flex-start; gap: 6px;
    padding: 20px 18px; border-radius: var(--radius); text-decoration: none;
    background: linear-gradient(150deg, color-mix(in srgb, var(--c) 22%, #ffffff), #ffffff);
    border: 1px solid var(--line); box-shadow: var(--shadow);
    transition: transform .18s ease, box-shadow .18s ease;
    color: var(--ink); min-height: 128px;
  }
  .cat-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
  .ce { font-size: 2.1rem; line-height: 1; }
  .cl { font-family: 'Baloo 2', cursive; font-weight: 800; font-size: 1.12rem; color: var(--ink); }
  .cd { color: var(--ink-soft); font-size: .88rem; }
  .cc { margin-top: auto; font-weight: 800; font-size: .82rem; color: var(--blue-d); background: #eaf1ff; padding: 3px 10px; border-radius: 999px; }
</style>
