---
import type { Story } from '../data/stories';
import CoverThumb from './CoverThumb.astro';
import { ageLabel, durationBucketForMinutes, storyCategoryLabel } from '../data/taxonomy';

interface Props { story: Story }
const { story } = Astro.props;
const d = story.data;
const href = `/masallar/${story.id}/`;
const category = d.categories[0] ? storyCategoryLabel(d.categories[0]) : 'Çocuk Masalı';
---
<a
  class="story-card"
  href={href}
  style={`--card-accent:${d.coverColor}`}
  data-title={d.title.toLowerCase()}
  data-desc={d.shortDescription.toLowerCase()}
  data-cats={d.categories.join(' ')}
  data-ages={d.ageGroups.join(' ')}
  data-dur={durationBucketForMinutes(d.readingTime)}
>
  <div class="thumb">
    <CoverThumb emoji={d.coverEmoji} color={d.coverColor} image={d.coverImage} alt={d.altText ?? d.title} ratio="4 / 3" />
    <span class="category-badge">{category}</span>
    {d.audioUrl && <span class="audio-badge">Sesli</span>}
  </div>
  <div class="body">
    <span class="eyebrow">MasalNova seçkisi</span>
    <h3>{d.title}</h3>
    <div class="meta">
      <span>{d.readingTime} dk okuma</span>
      {d.ageGroups[0] && <span>{ageLabel(d.ageGroups[0])}</span>}
      {d.audioUrl && <span>Sesli masal</span>}
    </div>
    <p class="desc">{d.shortDescription}</p>
    <span class="read-link">Masalı oku</span>
  </div>
</a>
<style>
  .story-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 30px;
    background:
      radial-gradient(120% 100% at 0% 0%, color-mix(in srgb, var(--card-accent) 50%, transparent), transparent 58%),
      linear-gradient(155deg, color-mix(in srgb, var(--card-accent) 34%, #132d62), #08152f 78%);
    color: #fff;
    box-shadow: 0 24px 64px rgba(5,18,52,.28);
    transition: transform .28s cubic-bezier(.2,.75,.25,1), box-shadow .28s ease, border-color .28s ease;
  }
  .story-card:hover {
    transform: translateY(-8px);
    border-color: rgba(255,255,255,.42);
    box-shadow: 0 34px 82px rgba(3,14,44,.4);
  }
  .thumb {
    position: relative;
    overflow: hidden;
    background: #0c2048;
  }
  .thumb::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 30%;
    background: linear-gradient(180deg, transparent, rgba(5,18,44,.34));
    pointer-events: none;
  }
  .thumb :global(.cover) {
    transition: transform .55s cubic-bezier(.2,.75,.25,1), filter .35s ease;
  }
  .story-card:hover .thumb :global(.cover) { transform: scale(1.045); filter: saturate(1.06); }
  .category-badge,
  .audio-badge {
    position: absolute;
    z-index: 2;
    top: 14px;
    padding: 7px 11px;
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 9px;
    background: rgba(5,16,38,.78);
    color: rgba(255,255,255,.94);
    box-shadow: 0 8px 22px rgba(0,0,0,.2);
    backdrop-filter: blur(12px);
    font-size: .75rem;
    font-weight: 800;
    line-height: 1;
  }
  .category-badge { right: 14px; }
  .audio-badge { left: 14px; }
  .body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 10px;
    min-height: 245px;
    padding: 22px 22px 24px;
  }
  .eyebrow {
    color: rgba(255,255,255,.68);
    font-size: .72rem;
    font-weight: 850;
    letter-spacing: .1em;
    text-transform: uppercase;
  }
  .body h3 {
    color: #fff;
    font-size: clamp(1.18rem,2vw,1.38rem);
    line-height: 1.2;
    letter-spacing: -.025em;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    color: rgba(255,255,255,.78);
    font-size: .78rem;
    font-weight: 750;
  }
  .meta span { display: inline-flex; align-items: center; }
  .meta span + span::before { content: "·"; margin: 0 8px; color: rgba(255,255,255,.42); }
  .desc {
    display: -webkit-box;
    overflow: hidden;
    color: rgba(255,255,255,.88);
    font-size: .91rem;
    font-weight: 560;
    line-height: 1.62;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
  }
  .read-link {
    align-self: flex-start;
    margin-top: auto;
    padding: 8px 13px;
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 999px;
    background: rgba(255,255,255,.12);
    color: #fff;
    font-size: .8rem;
    font-weight: 850;
    transition: background .2s ease, color .2s ease;
  }
  .story-card:hover .read-link { background: #fff; color: #102a66; }

  /* Hoppelpop's calmer catalogue layout, adapted to MasalNova's card markup.
     Archive grids become one-column below 900px, so the available width can
     be used for an easier-to-scan horizontal card. */
  @media (min-width: 641px) and (max-width: 900px) {
    :global(.story-grid) .story-card {
      display: grid;
      grid-template-columns: clamp(220px, 34vw, 310px) minmax(0, 1fr);
      min-height: 230px;
    }

    :global(.story-grid) .thumb,
    :global(.story-grid) .thumb :global(.cover) {
      width: 100%;
      height: 100%;
    }

    :global(.story-grid) .thumb :global(.cover) {
      aspect-ratio: auto !important;
    }

    :global(.story-grid) .body {
      min-height: 230px;
      padding: 20px 22px;
    }
  }

  @media (max-width: 640px) {
    .story-card { border-radius: 24px; }
    .body { min-height: 225px; padding: 18px 18px 20px; }
    .desc { -webkit-line-clamp: 3; }

    :global(.story-grid) .story-card {
      display: grid;
      grid-template-columns: 112px minmax(0, 1fr);
      min-height: 164px;
      border-radius: 20px;
    }

    :global(.story-grid) .thumb,
    :global(.story-grid) .thumb :global(.cover) {
      width: 112px;
      height: 100%;
      min-height: 164px;
    }

    :global(.story-grid) .thumb :global(.cover) {
      aspect-ratio: auto !important;
    }

    :global(.story-grid) .category-badge {
      top: 9px;
      right: 8px;
      max-width: 96px;
      overflow: hidden;
      padding: 5px 7px;
      font-size: .63rem;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    :global(.story-grid) .audio-badge { display: none; }

    :global(.story-grid) .body {
      gap: 6px;
      min-height: 164px;
      padding: 13px 14px;
    }

    :global(.story-grid) .eyebrow { display: none; }

    :global(.story-grid) .body h3 {
      display: -webkit-box;
      overflow: hidden;
      font-size: 1rem;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    :global(.story-grid) .meta {
      font-size: .69rem;
      line-height: 1.3;
    }

    :global(.story-grid) .desc {
      font-size: .78rem;
      line-height: 1.38;
      -webkit-line-clamp: 2;
    }

    :global(.story-grid) .read-link {
      padding: 5px 9px;
      font-size: .71rem;
    }
  }
</style>
