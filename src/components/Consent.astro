---
// Google Consent Mode v2 + GA4 + Silktide cookie banner.
// Ported 1:1 from the previous static site (Mess-ID G-YZYEN24W6J).
---
{/* Google Consent Mode v2 — default: everything denied until the user consents */}
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('consent', 'default', {
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    analytics_storage: 'denied',
    wait_for_update: 500
  });
</script>

{/* Google tag (gtag.js) */}
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-YZYEN24W6J"></script>
<script is:inline>
  gtag('js', new Date());
  gtag('config', 'G-YZYEN24W6J');
</script>

{/* Silktide Consent Manager — cookie banner in MasalNova colors */}
