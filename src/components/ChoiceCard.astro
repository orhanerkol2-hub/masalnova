---
interface Props {
  href: string;
  icon: string;
  title: string;
  subtitle: string;
  kind: 'story' | 'video';
}
const { href, icon, title, subtitle, kind } = Astro.props;
---
<a class={`choice choice-${kind}`} href={href}>
  <span class="ic" aria-hidden="true">{icon}</span>
  <span class="tx">
    <span class="t">{title}</span>
    <span class="s">{subtitle}</span>
  </span>
  <span class="arrow" aria-hidden="true">→</span>
</a>
<style>
  .choice {
    display: flex; align-items: center; gap: 18px; padding: 24px 24px;
    border-radius: var(--radius-lg); text-decoration: none; color: #fff;
    box-shadow: var(--shadow-lg); transition: transform .18s ease;
    border: 1px solid rgba(255, 255, 255, 0.18);
  }
  .choice:hover { transform: translateY(-4px); }
  .choice-story { background: linear-gradient(135deg, #ffb01f, #ff7a00); color: #4a2400; }
  .choice-video { background: linear-gradient(135deg, #2f74e8, #1b4fc4); color: #fff; }
  .ic { font-size: 2.6rem; line-height: 1; flex-shrink: 0; }
  .tx { display: flex; flex-direction: column; gap: 3px; flex: 1; }
  .t { font-family: var(--font-display); font-weight: 800; font-size: 1.4rem; }
  .s { font-size: .98rem; opacity: .92; font-weight: 600; }
  .arrow { font-size: 1.6rem; font-weight: 800; }
  @media (max-width: 420px) { .choice { padding: 20px; gap: 14px; } .t { font-size: 1.2rem; } }
</style>
